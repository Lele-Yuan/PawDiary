
/* ===== 登录弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.login-modal {
  width: 100%;
  background-color: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 40rpx 140rpx;
  max-height: 85vh;
  overflow-y: auto;
}

.login-modal-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #313333;
  text-align: center;
  margin-bottom: 12rpx;
}

.login-modal-desc {
  font-size: 26rpx;
  color: #888888;
  text-align: center;
  margin-bottom: 48rpx;
}

/* 头像选择器 */
.avatar-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: transparent;
  border: none;
  padding: 0;
  margin: 0 auto 40rpx;
  line-height: normal;
}

.avatar-picker::after {
  border: none;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx dashed #B8B8C8;
  margin-bottom: 16rpx;
}

.avatar-picker-hint {
  display: flex;
  align-items: center;
}

.avatar-picker-text {
  font-size: 26rpx;
  color: #E8875A;
  font-weight: 500;
}

/* 登录表单字段 */
.login-field {
  margin-bottom: 32rpx;
}

.login-field-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #5E5F5D;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
}

.login-field-input {
  width: 100%;
  height: 88rpx;
  background-color: #F5F3F1;
  border-radius: 24rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #313333;
  box-sizing: border-box;
}

/* 手机号授权按钮 */
.phone-auth-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #F5F3F1;
  border-radius: 24rpx;
  font-size: 30rpx;
  color: #888888;
  text-align: center;
  border: none;
  padding: 0;
  margin: 0;
}

.phone-auth-btn::after {
  border: none;
}

.phone-auth-btn.phone-authed {
  background-color: rgba(190, 235, 231, 0.3);
  color: #2E5956;
  font-weight: 600;
}

/* 登录操作按钮 */
.login-actions {
  margin-top: 48rpx;
}

.login-confirm-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #6B2D1A;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
  text-align: center;
  border: none;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-confirm-btn::after {
  border: none;
}

.login-cancel {
  text-align: center;
  color: #888888;
  font-size: 30rpx;
  padding: 16rpx 0;
}
