<view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
</view>
<view class="nav-bar-inner" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
  <view class="nav-bar-left" wx:if="{{back}}" bindtap="onBack">
    <view class="back-icon">‹</view>
  </view>
  <view class="nav-bar-title" style="opacity: {{titleOpacity}};">{{title}}</view>
  <view class="nav-bar-right">
    <slot name="right"></slot>
  </view>
</view>
<!-- 占位高度，防止内容被导航栏遮挡 -->
<view class="nav-bar-placeholder" style="height: {{statusBarHeight + navBarHeight}}px;"></view>