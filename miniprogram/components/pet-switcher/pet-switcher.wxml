<view class="pet-switcher">
  <scroll-view class="pet-list" scroll-x enable-flex>
    <view
      class="pet-item {{item._id === currentPetId ? 'active' : ''}}"
      wx:for="{{pets}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="onSelectPet"
    >
      <image
        class="pet-avatar"
        src="{{item.avatar || '/images/default/pet-avatar.png'}}"
        mode="aspectFill"
      />
      <view class="pet-name">{{item.name}}</view>
    </view>
    <view class="pet-item add-btn" bindtap="onAddPet">
      <view class="add-icon">+</view>
      <view class="pet-name">添加</view>
    </view>
  </scroll-view>
</view>