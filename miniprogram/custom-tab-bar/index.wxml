<view class="tab-bar">
  <view class="tab-bar-inner">
    <view
      wx:for="{{list}}"
      wx:key="pagePath"
      class="tab-item {{selected === index ? 'tab-item-active' : ''}}"
      bindtap="switchTab"
      data-path="{{item.pagePath}}"
      data-index="{{index}}"
    >
      <view class="tab-item-inner {{selected === index ? 'tab-pill' : ''}}">
        <image
          class="tab-icon"
          src="{{selected === index ? item.selectedIconPath : item.iconPath}}"
          mode="aspectFit"
        />
        <text class="tab-label {{selected === index ? 'tab-label-active' : ''}}">{{item.text}}</text>
      </view>
    </view>
  </view>
  <view class="tab-bar-safe-area"></view>
</view>
