<nav-bar title="记一笔" back="{{true}}" />

<view class="page-container">
  <!-- 金额输入 -->
  <view class="amount-section card">
    <view class="amount-label">消费金额</view>
    <view class="amount-input-wrap">
      <text class="amount-currency">¥</text>
      <input
        class="amount-input"
        type="digit"
        placeholder="0.00"
        value="{{form.amount}}"
        bindinput="onAmountInput"
        focus="{{true}}"
      />
    </view>
  </view>

  <!-- 分类选择 -->
  <view class="form-section card">
    <view class="form-label">消费分类 <text class="required">*</text></view>
    <view class="category-selector">
      <view
        class="category-item {{form.category === item.key ? 'active' : ''}}"
        wx:for="{{categoryList}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onSelectCategory"
      >
        <text class="category-icon">{{item.icon}}</text>
        <text class="category-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 其他表单 -->
  <view class="form-section card">
    <!-- 消费描述 -->
    <view class="form-group">
      <view class="form-label">消费描述 <text class="required">*</text></view>
      <input
        class="form-input"
        placeholder="如：皇家猫粮10kg"
        value="{{form.title}}"
        bindinput="onInputChange"
        data-field="title"
        maxlength="50"
      />
    </view>

    <!-- 日期 -->
    <view class="form-group">
      <view class="form-label">消费日期</view>
      <picker mode="date" value="{{form.date}}" end="{{today}}" bindchange="onDateChange">
        <view class="form-picker">
          <text class="{{form.date ? '' : 'placeholder'}}">{{form.date || '请选择日期'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 备注 -->
    <view class="form-group">
      <view class="form-label">备注</view>
      <input
        class="form-input"
        placeholder="选填"
        value="{{form.note}}"
        bindinput="onInputChange"
        data-field="note"
        maxlength="100"
      />
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="btn-section">
    <button
      class="btn-primary submit-btn"
      hover-class="btn-primary-hover"
      bindtap="onSubmit"
      loading="{{submitting}}"
    >
      保存账单
    </button>
  </view>
</view>