.page-container {
  padding-bottom: 60rpx;
}

/* 金额输入区 */
.amount-section {
  margin-top: 16rpx;
  text-align: center;
  padding: 48rpx 32rpx;
}

.amount-label {
  font-size: 26rpx;
  color: #888888;
  margin-bottom: 24rpx;
}

.amount-input-wrap {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.amount-currency {
  font-size: 44rpx;
  font-weight: 600;
  color: #6B2D1A;
  margin-right: 8rpx;
}

.amount-input {
  height: 72rpx;
  font-size: 72rpx;
  font-weight: 700;
  color: #2D2D2D;
  text-align: center;
  max-width: 400rpx;
}

/* 表单 */
.form-section {
  margin-top: 16rpx;
}

.required {
  color: #C0392B;
  margin-left: 4rpx;
}

/* 分类选择器 */
.category-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.category-item {
  width: calc(33.33% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background-color: #F5F0E8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.category-item.active {
  background-color: rgba(107, 45, 26, 0.1);
  border-color: #6B2D1A;
}

.category-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.category-label {
  font-size: 24rpx;
  color: #6B6B80;
}

.category-item.active .category-label {
  color: #6B2D1A;
  font-weight: 500;
}

/* 提交按钮 */
.btn-section {
  padding: 32rpx 24rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  font-size: 32rpx;
}