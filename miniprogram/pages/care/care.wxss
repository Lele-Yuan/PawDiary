/* ===== 代铲屎遛狗列表页 ===== */
.care-page {
  min-height: 100vh;
  padding-bottom: 180rpx;
}

/* 功能未开启时的提示 */
.feature-disabled-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

/* nav-bar 右侧发布按钮 */
.nav-publish-btn {
  font-size: 26rpx;
  font-weight: 600;
  color: #6B2D1A;
  background: rgba(107, 45, 26, 0.1);
  padding: 10rpx 20rpx;
  border-radius: 32rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 28rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  overflow-x: auto;
}

.filter-selector {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  border-radius: 60rpx;
  background: #F0EAD6;
  height: 32rpx;
}

.filter-selector-active {
  background: #6B2D1A;
}

.filter-selector-text {
  font-size: 26rpx;
  color: #6B2D1A;
  font-weight: 500;
  white-space: nowrap;
}

.filter-selector-active .filter-selector-text {
  color: #FFFFFF;
  font-weight: 600;
}

.filter-selector-arrow {
  font-size: 20rpx;
  color: #6B2D1A;
  line-height: 1;
}

.filter-selector-active .filter-selector-arrow {
  color: rgba(255, 255, 255, 0.8);
}

.filter-date-clear {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1;
  margin-left: 4rpx;
}

/* 只看我发布 */
.only-mine-btn {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 20rpx;
  border-radius: 60rpx;
  background: #F0EAD6;
  height: 32rpx;
  flex-shrink: 0;
}
.only-mine-btn-active {
  background: #6B2D1A;
}
.only-mine-check {
  font-size: 26rpx;
  color: #6B2D1A;
  line-height: 1;
}
.only-mine-btn-active .only-mine-check {
  color: #FFFFFF;
}
.only-mine-text {
  font-size: 26rpx;
  color: #6B2D1A;
  font-weight: 500;
  white-space: nowrap;
}
.only-mine-btn-active .only-mine-text {
  color: #FFFFFF;
  font-weight: 600;
}

.sort-btn {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  border-radius: 60rpx;
  background-color: #F0EAD6;
  flex-shrink: 0;
  height: 32rpx;
}

.sort-btn-text {
  font-size: 26rpx;
  color: #6B2D1A;
  font-weight: 600;
}

.sort-btn-arrow {
  font-size: 22rpx;
  color: #6B2D1A;
  margin-left: 6rpx;
}

/* 列表区域 */
.care-list {
  padding: 24rpx 28rpx 0;
  box-sizing: border-box;
}

/* 骨架屏 */
.loading-wrap {
  padding: 24rpx 0;
}

.skeleton-card {
  height: 260rpx;
  border-radius: 32rpx;
  background: linear-gradient(90deg, #F5F0EA 25%, #EDE8E0 50%, #F5F0EA 75%);
  background-size: 400% 100%;
  animation: shimmer 1.5s infinite;
  margin-bottom: 24rpx;
}

@keyframes shimmer {
  0% { background-position: 100% 0; }
  100% { background-position: -100% 0; }
}

/* 互助卡片 */
.care-card {
  background: #FFFFFF80;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.04);
  animation: fadeInUp 0.3s ease-out both;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 卡片头部 */
.care-card-header {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  flex: 1;
}

.header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.role-badge {
  font-size: 22rpx;
  font-weight: 600;
  padding: 6rpx 18rpx;
  border-radius: 24rpx;
}

.role-badge-helper {
  background: rgba(232, 135, 90, 0.12);
  color: #E8875A;
  border: 1rpx solid rgba(232, 135, 90, 0.4);
}

.role-badge-owner {
  background: rgba(142, 207, 201, 0.15);
  color: #3C6663;
  border: 1rpx solid rgba(142, 207, 201, 0.5);
}

.service-tags {
  display: flex;
  gap: 8rpx;
}

.service-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.tag-poop {
  background: #F5EDD0;
  color: #6B2D1A;
}

.tag-walk {
  background: #E8F5F4;
  color: #3C6663;
}

.tag-both {
  background: #F0F0F0;
  color: #555555;
}

.distance-text {
  font-size: 24rpx;
  color: #AAAAAA;
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 10rpx;
}

/* 发布人信息 */
.care-card-publisher {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F5F0EA;
}

.publisher-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #F5EDD0;
}

.publisher-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2D2D2D;
}

/* 详情信息 */
.care-card-body {
  margin-bottom: 20rpx;
}

.care-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  line-height: 1.4;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  font-size: 26rpx;
  width: 40rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.info-text {
  font-size: 26rpx;
  color: #444444;
  line-height: 1.5;
  flex: 1;
  min-width: 0;
  word-break: break-all;
}

.info-desc {
  color: #888888;
  font-style: italic;
}

/* 卡片底部 */
.care-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 20rpx;
  border-top: 1rpx solid #F5F0EA;
  gap: 16rpx;
}

.post-time {
  font-size: 22rpx;
  color: #BBBBBB;
  flex: 1;
}

.own-badge {
  font-size: 22rpx;
  color: #AAAAAA;
  background: #F5F0EA;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

/* 自己帖子的编辑/删除操作 */
.own-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.own-edit-btn {
  font-size: 24rpx;
  font-weight: 600;
  color: #6B2D1A;
  background: rgba(107, 45, 26, 0.08);
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
}

.own-delete-btn {
  font-size: 24rpx;
  font-weight: 600;
  color: #E8454A;
  background: rgba(232, 69, 74, 0.08);
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
}

.contact-btn {
  background: #6B2D1A;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 32rpx;
  border-radius: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(107, 45, 26, 0.25);
  flex-shrink: 0;
}

.contact-btn-loading {
  background: #BBBBBB;
  box-shadow: none;
}

.contact-revealed {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.contact-label {
  font-size: 20rpx;
  color: #AAAAAA;
}

.contact-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #3C6663;
}

/* 加载更多 / 结束 */
.load-more, .load-end {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #BBBBBB;
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80rpx;
}

.empty-cta {
  margin-top: 32rpx;
  background: #6B2D1A;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 64rpx;
  border-radius: 64rpx;
  box-shadow: 0 8rpx 24rpx rgba(107, 45, 26, 0.25);
}

/* 悬浮按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #E8875A;
  color: #FFFFFF;
  font-size: 52rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(232, 135, 90, 0.4);
  z-index: 999;
  line-height: 1;
}
