<view class="checklist-page">
  <nav-bar title="清单" titleOpacity="{{navTitleOpacity}}" />
  <!-- 顶部操作栏 -->
  <view class="top-bar">
    <view class="current-pet" wx:if="{{currentPetName}}">
      <text class="pet-tag">🐾 {{currentPetName}}</text>
    </view>
  </view>

  <!-- 清单分类卡片列表 -->
  <view wx:if="{{checklists.length}}">
    <view class="categories-header">
      <text class="categories-title">清单分类</text>
      <text class="categories-count">{{checklists.length}} 个清单</text>
    </view>

    <!-- 横向滚动卡片 -->
    <scroll-view class="cards-scroll" scroll-x enable-flex>
      <view
        class="checklist-card {{index % 2 === 0 ? 'card-beige' : 'card-teal'}} {{expandedId === item._id ? 'card-active' : ''}}"
        wx:for="{{checklists}}"
        wx:key="_id"
        data-id="{{item._id}}"
        bindtap="toggleDetail"
      >
        <!-- 图标圆形 -->
        <view class="card-icon-wrap">
          <text class="card-icon">{{item.icon || '📋'}}</text>
        </view>
        <!-- 标题 -->
        <text class="card-title {{index % 2 === 0 ? 'title-beige' : 'title-teal'}}">{{item.title}}</text>
        <!-- 进度条 -->
        <view class="card-progress-bar">
          <view class="card-progress-fill {{index % 2 === 0 ? 'fill-beige' : 'fill-teal'}}" style="width: {{item.progress}}%;"></view>
        </view>
        <!-- 计数 -->
        <text class="card-count {{index % 2 === 0 ? 'count-beige' : 'count-teal'}}">{{item.checkedCount}}/{{item.totalCount}} 已完成</text>
      </view>
    </scroll-view>
  </view>

  <!-- 空状态 -->
  <empty-state
    wx:if="{{!checklists.length && loaded}}"
    icon="📋"
    title="还没有清单"
    description="从模板快速创建或自定义新建一个清单吧"
    btnText="创建清单"
    bind:action="showCreateOptions"
  />

  <!-- 内联详情区域（样式与详情页完全一致） -->
  <view wx:if="{{expandedId && detailChecklist}}" class="detail-page">
    <view class="detail-card">
      <!-- 标题区 -->
      <view class="title-section">
        <view class="title-main">
          <view class="category-label">
            <text class="label-icon">{{detailChecklist.icon || '📋'}}</text>
            <text class="label-text">清单详情</text>
          </view>
          <input
            class="title-input"
            value="{{detailChecklist.title}}"
            placeholder="清单标题"
            bindblur="onTitleBlur"
            maxlength="30"
          />
          <text class="title-sub">共 {{detailTotalCount}} 项待办事项</text>
        </view>
        <view class="progress-badge">
          <text class="progress-num">{{detailProgress}}</text>
          <text class="progress-pct">%</text>
          <text class="progress-label-sm">完成</text>
        </view>
      </view>

      <!-- 进度条 -->
      <view class="detail-progress-bar">
        <view class="detail-progress-fill" style="width: {{detailProgress}}%;"></view>
      </view>

      <!-- 清单项列表 -->
      <view class="items-section">
        <view
          class="item-card {{item.checked ? 'item-checked' : 'item-unchecked'}}"
          wx:for="{{detailChecklist.items}}"
          wx:key="index"
        >
          <view class="item-main" data-index="{{index}}" bindtap="toggleItem">
            <view class="item-checkbox {{item.checked ? 'checkbox-checked' : 'checkbox-unchecked'}}">
              <text wx:if="{{item.checked}}" class="check-icon">✓</text>
            </view>
            <text class="item-name {{item.checked ? 'name-checked' : ''}}">{{item.name}}</text>
          </view>
          <view class="item-delete" data-index="{{index}}" bindtap="deleteItem">
            <text class="delete-icon">×</text>
          </view>
        </view>
      </view>

      <!-- 添加新项目：虚线 pill -->
      <view class="add-dashed" bindtap="focusAddInput">
        <text class="add-plus">+</text>
        <input
          class="add-input"
          id="addInput"
          placeholder="添加新项目"
          value="{{detailNewItemName}}"
          bindinput="onNewItemInput"
          bindconfirm="addItem"
          confirm-type="done"
        />
      </view>
    </view>

    <!-- 底部操作 -->
    <view class="bottom-actions">
      <button class="btn-outline delete-list-btn" hover-class="btn-outline-hover" bindtap="deleteChecklist">
        删除此清单
      </button>
    </view>
  </view>

  <!-- FAB：详情展开时添加条目，否则新建清单 -->
  <view wx:if="{{expandedId && detailChecklist && canEdit}}" class="detail-fab" bindtap="addItem">
    <text class="fab-icon">+</text>
  </view>
  <view wx:elif="{{!expandedId && canEdit}}" class="fab-btn" hover-class="fab-btn-hover" bindtap="showCreateOptions">+</view>

  <!-- 模板选择弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="hideModal">
    <view class="modal-content" catchtap>
      <view class="modal-title">选择创建方式</view>

      <view class="modal-section-title">从模板创建</view>
      <view
        class="template-item"
        wx:for="{{templates}}"
        wx:key="_id"
        data-id="{{item._id}}"
        bindtap="createFromTemplate"
      >
        <text class="template-icon">{{item.icon}}</text>
        <view class="template-info">
          <text class="template-name">{{item.title}}</text>
          <text class="template-desc">{{item.description}}</text>
        </view>
      </view>

      <view class="modal-section-title">自定义创建</view>
      <view class="custom-create">
        <input
          class="form-input"
          placeholder="输入清单名称"
          value="{{customTitle}}"
          bindinput="onCustomTitleInput"
        />
        <button
          class="btn-primary btn-small create-btn"
          hover-class="btn-primary-hover"
          bindtap="createCustom"
        >创建</button>
      </view>

      <view class="modal-close" bindtap="hideModal">取消</view>
    </view>
  </view>
</view>
