.checklist-page {
  padding-bottom: 160rpx;
}

/* ===== 顶部操作栏 ===== */
.top-bar {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  padding: 24rpx 32rpx 8rpx;
}

.pet-tag {
  font-size: 26rpx;
  color: #6B2D1A;
  background-color: #F5EDD0;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* ===== 分类标题行 ===== */
.categories-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx 20rpx;
}

.categories-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D2D2D;
  letter-spacing: -1rpx;
}

.categories-count {
  font-size: 26rpx;
  color: #888888;
}

/* ===== 横向滚动容器 ===== */
.cards-scroll {
  display: flex;
  flex-direction: row;
  padding: 8rpx 32rpx 24rpx;
  white-space: nowrap;
  width: auto;
}

/* ===== 清单卡片 ===== */
.checklist-card {
  display: inline-flex;
  flex-direction: column;
  justify-content: flex-start;
  width: 320rpx;
  min-height: 280rpx;
  border-radius: 64rpx;
  padding: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-sizing: border-box;
  transition: opacity 0.2s ease;
}

.checklist-card:active {
  opacity: 0.85;
}

/* 选中态：更深边框 */
.card-active {
  box-shadow: 0 0 8rpx 8rpx rgba(60, 102, 99, 0.1);
}

/* 米黄色变体 */
.card-beige { background-color: #F5E6CC; }
/* 薄荷绿变体 */
.card-teal  { background-color: #BEE3E7; }

/* 图标圆形底座 */
.card-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.card-icon {
  font-size: 40rpx;
  line-height: 1;
}

/* 卡片中间内容区 */
.card-body {
  flex: 1;
  min-width: 0;
}

/* 标题 */
.card-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.title-beige { color: #5E5440; }
.title-teal  { color: #2E5956; }

/* 进度条 */
.card-progress-bar {
  width: 100%;
  height: 10rpx;
  border-radius: 10rpx;
  background-color: rgba(255, 255, 255, 0.4);
  margin-bottom: 8rpx;
  overflow: hidden;
}

.card-progress-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.fill-beige { background-color: #5E5440; }
.fill-teal  { background-color: #2E5956; }

/* 计数文字 */
.card-count {
  font-size: 22rpx;
  font-weight: 600;
}

.count-beige { color: #5E5440; }
.count-teal  { color: #2E5956; }

/* 展开箭头 */
.card-arrow {
  font-size: 44rpx;
  font-weight: 300;
  flex-shrink: 0;
  margin-left: 12rpx;
  transition: transform 0.25s ease;
  line-height: 1;
}

.arrow-down {
  transform: rotate(90deg);
}

/* ===== 内联详情区域（与 checklist-detail 样式完全一致） ===== */
.detail-page {
  padding: 16rpx 28rpx 200rpx;
}

.detail-card {
  background: linear-gradient(135deg, #FFFFFF 65%, rgba(232, 135, 90, 0.07) 100%);
  border-radius: 96rpx;
  box-shadow: 0 40rpx 80rpx rgba(149, 73, 49, 0.06);
  padding: 56rpx 52rpx 48rpx;
}

/* 标题区 */
.title-section {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 48rpx;
}

.title-main {
  flex: 1;
  min-width: 0;
  margin-right: 24rpx;
}

.category-label {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.label-icon {
  font-size: 22rpx;
  margin-right: 8rpx;
  line-height: 1;
}

.label-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #5E5F5D;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

.title-input {
  height: 56rpx;
  font-size: 56rpx;
  font-weight: 800;
  color: #313333;
  line-height: 1.2;
  padding: 0;
  border: none;
  background: transparent;
  margin-bottom: 8rpx;
  width: 100%;
}

.title-sub {
  font-size: 26rpx;
  color: #5E5F5D;
}

.progress-badge {
  padding-top: 24rpx;
}

.progress-num {
  font-size: 60rpx;
  font-weight: 900;
  color: #3C6663;
  line-height: 1;
}

.progress-pct {
  font-size: 28rpx;
  font-weight: 900;
  color: #3C6663;
  align-self: flex-start;
  margin-top: 6rpx;
}

.progress-label-sm {
  font-size: 20rpx;
  font-weight: 700;
  color: #5E5F5D;
  letter-spacing: 1rpx;
  text-transform: uppercase;
  margin-top: 4rpx;
}

/* 进度条 */
.detail-progress-bar {
  width: 100%;
  height: 24rpx;
  border-radius: 24rpx;
  background-color: #EFEEEB;
  overflow: hidden;
  margin-bottom: 48rpx;
}

.detail-progress-fill {
  height: 100%;
  border-radius: 24rpx;
  background-color: #3C6663;
  transition: width 0.3s ease;
}

/* 清单项列表 */
.items-section {
  margin-bottom: 24rpx;
}

.item-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  border-radius: 64rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
}

.item-checked {
  background-color: #F5F3F1;
  opacity: 0.6;
}

.item-unchecked {
  background: linear-gradient(135deg, #FFFFFF 60%, rgba(232, 135, 90, 0.06) 100%);
  border: 2rpx solid rgba(60, 102, 99, 0.2);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.item-main {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.item-checkbox {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 28rpx;
  flex-shrink: 0;
}

.checkbox-checked {
  background-color: #3C6663;
  border: none;
}

.checkbox-unchecked {
  border: 4rpx solid rgba(60, 102, 99, 0.3);
  background-color: transparent;
}

.check-icon {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
}

.item-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #313333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.name-checked {
  text-decoration: line-through;
  color: #5E5F5D;
}

.item-delete {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.delete-icon {
  font-size: 36rpx;
  color: #B1B2B0;
  font-weight: 300;
  line-height: 1;
}

.item-delete:active .delete-icon {
  color: #C0392B;
}

/* 添加新项目：虚线 pill */
.add-dashed {
  display: flex;
  flex-direction: row;
  align-items: center;
  border-radius: 60rpx;
  border: 4rpx dashed rgba(177, 178, 176, 1);
  padding: 24rpx 32rpx;
  height: 112rpx;
  box-sizing: border-box;
}

.add-plus {
  font-size: 36rpx;
  font-weight: 300;
  color: #5E5F5D;
  margin-right: 16rpx;
  line-height: 1;
  flex-shrink: 0;
}

.add-input {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #5E5F5D;
  background: transparent;
  border: none;
  padding: 0;
}

/* 底部删除操作 */
.bottom-actions {
  padding: 32rpx 0 0;
}

.delete-list-btn {
  width: 100%;
  color: #888888;
  border-color: #CCCCCC;
  font-size: 28rpx;
}

.delete-list-btn::after {
  border: none;
}

/* 详情区 FAB */
.detail-fab {
  position: fixed;
  right: 40rpx;
  bottom: 136rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background-color: #FE9D7F;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.15), 0 40rpx 50rpx rgba(0, 0, 0, 0.10);
  z-index: 100;
}

.detail-fab:active {
  transform: scale(0.92);
  opacity: 0.9;
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* ===== 弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background-color: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx 164rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D2D2D;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-section-title {
  font-size: 26rpx;
  color: #888888;
  margin: 24rpx 0 16rpx;
  font-weight: 500;
}

.template-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background-color: #F5F0E8;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.template-item:active { background-color: #F0F0F0; }

.template-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.template-info { flex: 1; min-width: 0; }

.template-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #2D2D2D;
  display: block;
  margin-bottom: 4rpx;
}

.template-desc {
  font-size: 24rpx;
  color: #888888;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.custom-create {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.custom-create .form-input { flex: 1; }
.create-btn { flex-shrink: 0; }

.modal-close {
  text-align: center;
  color: #888888;
  font-size: 30rpx;
  padding: 32rpx 0 16rpx;
}
