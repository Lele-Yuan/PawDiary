.pet-hero {
  position: relative;
  margin: 0;
  padding: 0 32rpx 44rpx;
  overflow: hidden;
  border-radius: 0 0 56rpx 56rpx;
  background: linear-gradient(145deg, #f9d568 0%, #f0c6ae 52%, #f9d568 100%);
  box-shadow: 0 18rpx 40rpx rgba(224, 109, 110, 0.22);
}

.hero-safe-space {
  position: relative;
  z-index: 1;
}

.hero-deco {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.hero-deco-top {
  top: -140rpx;
  right: -80rpx;
  width: 360rpx;
  height: 360rpx;
  background: rgba(255, 255, 255, 0.18);
}

.hero-deco-bottom {
  bottom: -180rpx;
  left: -140rpx;
  width: 420rpx;
  height: 420rpx;
  background: rgba(255, 221, 209, 0.26);
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 28rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
  padding-top: 24rpx;
}

.hero-caption {
  font-size: 24rpx;
  line-height: 1.4;
  letter-spacing: 6rpx;
  color: rgba(255, 255, 255, 0.78);
  margin-bottom: 18rpx;
}

.hero-name {
  font-size: 64rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 14rpx;
  word-break: break-all;
}

.hero-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  min-height: 36rpx;
}

.hero-meta-text,
.hero-meta-dot {
  font-size: 26rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.84);
}

.hero-stats {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.hero-stat {
  min-width: 148rpx;
  padding: 16rpx 20rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.22);
  backdrop-filter: blur(14rpx);
}

.hero-stat-value {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #FFFFFF;
}

.hero-stat-unit {
  margin-left: 4rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.hero-stat-label {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.4;
  color: rgba(255, 255, 255, 0.72);
}

.hero-avatar-wrap {
  position: relative;
  flex-shrink: 0;
  margin-top: 18rpx;
}

.hero-avatar {
  width: 220rpx;
  height: 220rpx;
  display: block;
  border-radius: 52rpx;
  transform: rotate(6deg);
  background: rgba(255, 255, 255, 0.18);
  box-shadow: 0 20rpx 32rpx rgba(138, 55, 66, 0.18);
}

.gender-badge {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 24rpx;
  color: #FFFFFF;
  border: 3rpx solid rgba(255, 255, 255, 0.9);
}

.gender-badge.male {
  background-color: #3C6663;
}

.gender-badge.female {
  background-color: #EC4899;
}
