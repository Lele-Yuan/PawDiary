<view class="home-page">
  <!-- 无宠物时的引导页（Figma 设计稿还原） -->
  <view wx:if="{{!pets.length && loaded}}" class="welcome-page">
    <!-- 背景装饰图 -->
    <image class="deco-top" src="/images/guide/deco-top.png" mode="aspectFit" />
    <image class="deco-bottom" src="/images/guide/deco-bottom.png" mode="aspectFit" />

    <!-- 顶部导航栏 -->
    <view class="welcome-nav" style="padding-top: {{statusBarHeight}}px;">
      <view class="welcome-nav-left">
        <image class="welcome-logo" src="/images/tab/tab-home.png" mode="aspectFit" />
        <text class="welcome-app-name">PawDiary</text>
      </view>
    </view>

    <!-- 主体内容 -->
    <view class="welcome-body">
      <!-- 插画区域 -->
      <view class="welcome-illust-wrap">
        <image class="welcome-illust-bg1" src="/images/guide/illust-bg-1.png" mode="aspectFit" />
        <image class="welcome-illust-bg2" src="/images/guide/illust-bg-2.png" mode="aspectFit" />
        <image class="welcome-illust" src="/images/guide/illust-main.png" mode="aspectFit" />
      </view>

      <!-- 文案区域 -->
      <view class="welcome-text">
        <view class="welcome-title">欢迎来到</view>
        <view class="welcome-title">宠物管家</view>
        <view class="welcome-desc">让您的爱宠享受高端定制的贴心</view>
        <view class="welcome-desc">管家服务。</view>
      </view>
    </view>

    <!-- 底部操作区 -->
    <view class="welcome-footer">
      <view class="welcome-cta" hover-class="welcome-cta-hover" bindtap="goAddPet">
        <text class="welcome-cta-text">开启宠爱之旅</text>
        <image class="welcome-cta-arrow" src="/images/guide/arrow-right.png" mode="aspectFit" />
      </view>
      <view class="welcome-slogan">LUXURY PET MANAGEMENT • ESTABLISHED 2024</view>
    </view>
  </view>

  <!-- 有宠物时的正常页面 -->
  <view wx:if="{{pets.length}}" class="fade-in">
    <!-- 宠物信息卡片 -->
    <pet-card
      wx:if="{{currentPet}}"
      pet="{{currentPet}}"
      statusBarHeight="{{statusBarHeight}}"
      bind:edit="onEditPet"
    />

    <!-- 快捷功能入口 -->
    <view class="quick-entry card">
      <view class="entry-grid">
        <view class="entry-item" bindtap="goChecklist">
          <view class="entry-icon entry-icon-dark">📋</view>
          <view class="entry-label">清单</view>
        </view>
        <view class="entry-item" bindtap="goRecord">
          <view class="entry-icon entry-icon-teal">📝</view>
          <view class="entry-label">记录</view>
        </view>
        <view class="entry-item" bindtap="goBill">
          <view class="entry-icon entry-icon-beige">💰</view>
          <view class="entry-label">账单</view>
        </view>
        <view class="entry-item" bindtap="goEditWeight">
          <view class="entry-icon entry-icon-gray">⚖️</view>
          <view class="entry-label">体重记录</view>
        </view>
      </view>
    </view>

    <!-- 家庭成员 -->
    <view class="family-section card" wx:if="{{currentPet}}">
      <view class="section-header">
        <text class="section-title">家庭成员</text>
        <button class="invite-btn" open-type="share" wx:if="{{canEdit}}">邀请 +</button>
      </view>
      <view class="family-list">
        <view class="family-item" wx:for="{{familyMembers}}" wx:key="_id">
          <image class="family-avatar" src="{{item.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
          <view class="family-info">
            <text class="family-name">{{item.nickName}}</text>
            <text class="family-role role-{{item.role}}">{{item.roleLabel}}</text>
          </view>
          <view class="family-actions" wx:if="{{isCreator && item.role !== 'creator'}}">
            <text
              class="family-action-btn"
              data-openid="{{item._openid}}"
              data-role="{{item.role}}"
              bindtap="onToggleRole"
            >{{item.role === 'admin' ? '取消管理' : '设为管理'}}</text>
            <text
              class="family-action-btn danger"
              data-openid="{{item._openid}}"
              bindtap="onRemoveMember"
            >移除</text>
          </view>
        </view>
      </view>
      <view class="family-empty" wx:if="{{familyMembers.length <= 1}}">
        <text class="family-empty-text">暂无其他家庭成员，邀请家人一起照顾毛孩子吧</text>
      </view>
    </view>

    <!-- 指南模块 -->
    <view class="guide-links">
      <view class="guide-link guide-link-cat">
        <view class="guide-link-copy">
          <view class="guide-link-title">养猫指南</view>
          <view class="guide-link-desc">了解猫咪养护知识</view>
        </view>
        <view class="guide-link-deco">🐱</view>
      </view>
      <view class="guide-link guide-link-dog">
        <view class="guide-link-copy">
          <view class="guide-link-title">养狗指南</view>
          <view class="guide-link-desc">狗狗养育完全手册</view>
        </view>
        <view class="guide-link-deco">🐶</view>
      </view>
    </view>

    <!-- 近期提醒 -->
    <view class="reminders-section" wx:if="{{upcomingReminders.length}}">
      <view class="section-header">
        <text class="section-title">近期提醒</text>
        <text class="section-more" bindtap="goRecord">查看全部 ›</text>
      </view>

      <view class="reminder-card card-sm" wx:for="{{upcomingReminders}}" wx:key="_id">
        <view class="reminder-left">
          <view class="reminder-dot" style="background-color: {{item.typeColor}};"></view>
        </view>
        <view class="reminder-content">
          <view class="reminder-title">{{item.title}}</view>
          <view class="reminder-info">
            <text class="reminder-type tag {{item.tagClass}}">{{item.typeLabel}}</text>
            <text class="reminder-date">{{item.nextDateStr}}</text>
          </view>
        </view>
        <view class="reminder-countdown">
          <text class="countdown-num">{{item.daysLeft}}</text>
          <text class="countdown-label">天后</text>
        </view>
      </view>
    </view>

    <!-- 无提醒时的友好提示 -->
    <view class="no-reminder card-sm" wx:if="{{!upcomingReminders.length && loaded}}">
      <text class="no-reminder-icon">🎉</text>
      <text class="no-reminder-text">暂无待处理提醒，毛孩子一切安好~</text>
    </view>
  </view>
</view>