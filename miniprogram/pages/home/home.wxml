<!-- 无宠物时的引导页（Figma 设计稿还原） -->
<view wx:if="{{!pets.length && loaded}}" class="welcome-page">
  <!-- 背景装饰 -->
  <view class="deco-top"></view>
  <view class="deco-bottom"></view>

  <!-- 顶部导航栏 -->
  <view class="welcome-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="welcome-nav-left">
      <image class="welcome-logo" src="/images/tab/tab-profile-active.png" mode="aspectFit" />
      <text class="welcome-app-name">PawDiary</text>
    </view>
  </view>

  <!-- 主体内容 -->
  <view class="welcome-body">
    <!-- 插画区域 -->
    <view class="welcome-illust-wrap">
      <view class="welcome-illust-bg1"></view>
      <view class="welcome-illust-bg2"></view>
      <image class="welcome-illust" src="/images/guide/illust-main.png" mode="aspectFit" />
    </view>

    <!-- 文案区域 -->
    <view class="welcome-text">
      <view class="welcome-title">欢迎来到</view>
      <view class="welcome-title">宠物管家</view>
      <view class="welcome-desc">让您的爱宠享受高端定制的贴心管家服务</view>
    </view>
  </view>

  <!-- 底部操作区 -->
  <view class="welcome-footer">
    <view class="welcome-cta" hover-class="welcome-cta-hover" bindtap="goAddPet">
      <text class="welcome-cta-text">开启宠爱之旅</text>
    </view>
    <view class="welcome-slogan">PAW DIARY MANAGEMENT • ESTABLISHED 2026</view>
  </view>
</view>

<view class="home-page" wx:if="{{pets.length}}">
  <!-- 有宠物时的正常页面 -->
  <view class="fade-in">
    <!-- 宠物信息卡片 -->
    <pet-card
      wx:if="{{currentPet}}"
      pet="{{currentPet}}"
      statusBarHeight="{{statusBarHeight}}"
      bind:edit="onEditPet"
    />

    <!-- 家庭成员 -->
    <view class="family-section card" wx:if="{{currentPet}}">
      <view class="section-header">
        <text class="section-title">家庭成员</text>
      </view>
      <view class="family-row">
        <view
          class="family-member {{item.role === 'creator' || item.role === 'admin' ? 'family-member-active' : ''}}"
          wx:for="{{familyMembers}}"
          wx:key="_id"
          data-openid="{{item._openid}}"
          data-role="{{item.role}}"
          bindlongpress="onMemberLongPress"
        >
          <view class="family-member-avatar-wrap {{item.role === 'creator' ? 'avatar-border-active' : ''}}">
            <image
              class="family-member-avatar"
              src="{{item.avatarUrl || '/images/default-avatar.png'}}"
              mode="aspectFill"
              data-openid="{{item._openid}}"
              binderror="onAvatarError"
            />
          </view>
          <text class="family-member-name {{item.role === 'creator' ? 'name-active' : ''}}">{{item.nickName}}</text>
        </view>
        <!-- 邀请按钮，当成员不足5个且有编辑权限时显示 -->
        <button class="family-member family-member-add" open-type="share" wx:if="{{familyMembers.length < 5 && canEdit}}">
          <view class="family-member-avatar-wrap avatar-border-dashed">+</view>
          <text class="family-member-name name-muted">邀请成员</text>
        </button>
      </view>
    </view>

    <!-- 指南模块 -->
    <view class="guide-links">
      <view class="guide-link guide-link-map" bindtap="goMap">
        <view class="guide-link-copy">
          <view class="guide-link-title">宠好地图</view>
          <view class="guide-link-desc">标记一处宠物友好地点，喊上好友去遛狗</view>
        </view>
        <view class="guide-link-deco">🗺️</view>
      </view>
    </view>

    <!-- 宠物互助入口 -->
    <view class="care-entry-wrap" bindtap="goToCare">
      <view class="care-entry-left">
        <view class="care-entry-icon-wrap">
          <text class="care-entry-icon">🐾</text>
        </view>
        <view class="care-entry-text">
          <text class="care-entry-title">代铲屎遛狗</text>
          <text class="care-entry-desc">附近宠物互助，轻松找搭子</text>
        </view>
      </view>
      <view class="care-entry-tags">
        <text class="care-tag care-tag-helper">临时主</text>
        <text class="care-tag care-tag-owner">需求方</text>
      </view>
      <text class="care-entry-arrow">›</text>
    </view>

    <!-- 近期提醒 -->
    <view class="reminders-section" wx:if="{{upcomingReminders.length}}">
      <view class="section-header">
        <text class="section-title">近期提醒</text>
        <text class="section-more" bindtap="goRecord">查看全部 ›</text>
      </view>

      <view class="reminder-card card-sm" wx:for="{{upcomingReminders}}" wx:key="_id">
        <view class="reminder-left">
          <view class="reminder-dot" style="background-color: {{item.typeColor}};"></view>
        </view>
        <view class="reminder-content">
          <view class="reminder-title">{{item.title}}</view>
          <view class="reminder-info">
            <text class="reminder-type tag {{item.tagClass}}">{{item.typeLabel}}</text>
            <text class="reminder-date">{{item.nextDateStr}}</text>
          </view>
        </view>
        <view class="reminder-countdown" wx:if="{{item.daysLeft >= 0}}">
          <view class="countdown-label"><text class="countdown-num">{{item.daysLeft}} </text>天后</view>
        </view>
        <view class="reminder-countdown" wx:if="{{item.daysLeft < 0}}">
          <view class="countdown-label">已超期<text class="countdown-num"> {{-item.daysLeft}} </text>天</view>
        </view>
      </view>
    </view>

    <!-- 无提醒时的友好提示 -->
    <view class="no-reminder card-sm" wx:if="{{!upcomingReminders.length && loaded}}">
      <text class="no-reminder-icon">🎉</text>
      <text class="no-reminder-text">暂无待处理提醒，毛孩子一切安好~</text>
    </view>
  </view>
</view>

<!-- 登录弹窗组件 -->
<login-modal
  show="{{showLoginModal}}"
  avatarUrl="{{userInfo.avatarUrl}}"
  nickName="{{userInfo.nickName}}"
  phone="{{userInfo.phone}}"
  bind:success="onLoginSuccess"
  bind:close="onLoginClose"
/>