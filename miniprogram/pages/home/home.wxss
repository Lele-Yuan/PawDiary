.home-page {
  padding-bottom: 120rpx;
}

.home-safe-space {
  width: 100%;
  flex-shrink: 0;
}

/* ===== 快捷入口 ===== */
.quick-entry {
  margin-top: 24rpx;
  border-radius: 40rpx;
  padding: 32rpx 24rpx 24rpx;
}

.entry-grid {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 8rpx;
}

.entry-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  transition: opacity 0.2s ease;
}

.entry-item:active {
  opacity: 0.82;
}

.entry-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  line-height: 1;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.06);
}

.entry-icon-dark {
  background-color: #6B2D1A;
  color: #FFFFFF;
}

.entry-icon-teal {
  background-color: #8ECFC9;
  color: #2D2D2D;
}

.entry-icon-beige {
  background-color: #EDD9A3;
  color: #2D2D2D;
}

.entry-icon-gray {
  background-color: #E8E2DA;
  color: #2D2D2D;
}

.entry-label {
  font-size: 24rpx;
  line-height: 1.4;
  font-weight: 500;
  color: #2D2D2D;
  text-align: center;
}

/* ===== 指南模块 ===== */
.guide-links {
  display: flex;
  gap: 16rpx;
  margin: 0 28rpx 24rpx;
}

.guide-link {
  position: relative;
  flex: 1;
  min-height: 176rpx;
  padding: 28rpx 24rpx;
  border-radius: 32rpx;
  overflow: hidden;
}

.guide-link-copy {
  position: relative;
  z-index: 1;
}

.guide-link-title {
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #2D2D2D;
}

.guide-link-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(45, 45, 45, 0.66);
}

.guide-link-deco {
  position: absolute;
  right: 20rpx;
  bottom: 10rpx;
  font-size: 70rpx;
  line-height: 1;
  opacity: 0.28;
}

.guide-link-cat {
  background: linear-gradient(145deg, #ECE6F9 0%, #E3DDF4 100%);
}

.guide-link-dog {
  background: linear-gradient(145deg, #DDF1EF 0%, #CFE8E4 100%);
}

/* ===== 提醒区域 ===== */
.reminders-section {
  margin-top: 8rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 24rpx;
  margin-bottom: 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
}

.section-more {
  font-size: 24rpx;
  color: #E8875A;
}

/* 提醒卡片 */
.reminder-card {
  display: flex;
  align-items: center;
}

.reminder-left {
  margin-right: 20rpx;
}

.reminder-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.reminder-content {
  flex: 1;
  min-width: 0;
}

.reminder-title {
  font-size: 28rpx;
  color: #2D2D2D;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reminder-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.reminder-type {
  flex-shrink: 0;
}

.reminder-date {
  font-size: 24rpx;
  color: #888888;
}

.reminder-countdown {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.countdown-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #6B2D1A;
}

.countdown-label {
  font-size: 20rpx;
  color: #888888;
}

/* 无提醒 */
.no-reminder {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.no-reminder-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.no-reminder-text {
  font-size: 26rpx;
  color: #888888;
}
