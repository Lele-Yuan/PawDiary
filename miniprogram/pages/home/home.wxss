.home-page {
  padding-bottom: 180rpx;
}

.home-safe-space {
  width: 100%;
  flex-shrink: 0;
}

/* ===== 无宠物欢迎页 ===== */
.welcome-page {
  position: relative;
  width: 100%;
  min-height: 100vh;
  background-color: #FBF9F7;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  position: relative;
  z-index: 10000;
}

/* 背景装饰 */
.deco-top {
  position: absolute;
  top: 216rpx;
  right: -80rpx;
  width: 624rpx;
  height: 1083rpx;
  opacity: 0.35;
  pointer-events: none;
  background: radial-gradient(ellipse at 40% 30%, rgba(232, 135, 90, 0.3) 0%, rgba(237, 217, 163, 0.2) 40%, transparent 70%);
  border-radius: 50% 30% 50% 40%;
  transform: rotate(-12deg);
}

.deco-bottom {
  position: absolute;
  bottom: 0;
  left: -78rpx;
  width: 468rpx;
  height: 866rpx;
  opacity: 0.35;
  pointer-events: none;
  background: radial-gradient(ellipse at 60% 70%, rgba(149, 73, 49, 0.25) 0%, rgba(232, 135, 90, 0.15) 35%, transparent 65%);
  border-radius: 40% 50% 30% 50%;
  transform: rotate(15deg);
}

/* 顶部导航 */
.welcome-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-left: 32rpx;
  padding-right: 32rpx;
  padding-bottom: 16rpx;
  position: relative;
  z-index: 2;
}

.welcome-nav-left {
  display: flex;
  align-items: center;
}

.welcome-logo {
  width: 40rpx;
  height: 38rpx;
  margin-right: 16rpx;
  transform: rotate(-45deg);
}

.welcome-app-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #313331;
  letter-spacing: -0.7rpx;
}

/* 主体内容 */
.welcome-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 0 64rpx;
  position: relative;
  z-index: 1;
}

/* 插画 */
.welcome-illust-wrap {
  position: relative;
  width: 652rpx;
  height: 650rpx;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.welcome-illust-bg1 {
  position: absolute;
  top: 4rpx;
  left: -3rpx;
  width: 658rpx;
  height: 641rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse at 50% 50%, rgba(237, 217, 163, 0.5) 0%, rgba(240, 234, 214, 0.35) 50%, transparent 75%);
  transform: rotate(-6deg);
}

.welcome-illust-bg2 {
  position: absolute;
  top: 10rpx;
  left: 3rpx;
  width: 646rpx;
  height: 629rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse at 50% 50%, rgba(232, 135, 90, 0.15) 0%, rgba(245, 237, 208, 0.25) 45%, transparent 70%);
  transform: rotate(4deg);
}

.welcome-illust {
  position: relative;
  width: 650rpx;
  height: 650rpx;
}

/* 文案 */
.welcome-text {
  margin-top: 0;
  padding-bottom: 96rpx;
}

.welcome-title {
  font-size: 72rpx;
  font-weight: 800;
  color: #954931;
  line-height: 90rpx;
  letter-spacing: -3.6rpx;
}

.welcome-desc {
  font-size: 36rpx;
  font-weight: 500;
  color: #5E5F5D;
  line-height: 58rpx;
}

.welcome-desc:first-of-type {
  margin-top: 8rpx;
}

/* 底部操作区 */
.welcome-footer {
  position: relative;
  z-index: 2;
  padding: 32rpx 64rpx 128rpx;
  background: linear-gradient(0deg, rgba(251,249,247,1) 0%, rgba(251,249,247,0.9) 50%, rgba(251,249,247,0) 100%);
}

.welcome-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 120rpx;
  border-radius: 60rpx;
  background-color: #954931;
  margin-bottom: 48rpx;
}

.welcome-cta-hover {
  opacity: 0.85;
}

.welcome-cta-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFF7F5;
  margin-right: 16rpx;
}

.welcome-slogan {
  font-size: 20rpx;
  font-weight: 700;
  color: #5E5F5D;
  text-align: center;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* ===== 指南模块 ===== */
.guide-links {
  display: flex;
  gap: 16rpx;
  margin: 0 28rpx 24rpx;
}

.guide-link {
  position: relative;
  flex: 1;
  padding: 28rpx 24rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.guide-link-copy {
  position: relative;
  z-index: 1;
}

.guide-link-title {
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #2D2D2D;
}

.guide-link-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(45, 45, 45, 0.66);
}

.guide-link-deco {
  position: absolute;
  right: 20rpx;
  bottom: 10rpx;
  font-size: 70rpx;
  line-height: 1;
  opacity: 0.28;
}

.guide-link-map-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: .5;
}

.guide-link-map {
  background: linear-gradient(145deg, #DDF1EF 0%, #CFE8E4 100%);
}

.guide-link-dog {
  background: linear-gradient(145deg, #F5E6CC 0%, rgba(254, 157, 127, 0.2) 100%);
}

/* ===== 家庭成员 ===== */
.family-section {
  margin-top: 24rpx;
  padding: 32rpx 24rpx 24rpx;
  border-radius: 40rpx;
}

.family-section .section-header {
  padding: 0;
  margin-bottom: 24rpx;
}

/* 家庭成员横向排列 */
.family-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 0 8rpx;
  overflow-x: auto;
}

.family-member {
  width: 128rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 24rpx;
  opacity: 0.6;
  background: none;
  border: none;
  padding: 0;
  line-height: normal;
  flex-shrink: 0;
}

.family-member::after {
  border: none;
}

.family-member:last-child {
  margin-right: 0;
}

.family-member-active {
  opacity: 1;
}

.family-member-avatar-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.avatar-border-active {
  border-color: #954931;
}

.avatar-border-dashed {
  border: 4rpx dashed #B1B2B0;
}

.family-member-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
}

.family-member-name {
  font-size: 20rpx;
  font-weight: 700;
  color: #313331;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 128rpx;
}

.name-active {
  color: #954931;
}

.name-muted {
  color: #7A7B79;
}

wx-button:not([size=mini]).family-member-add {
  opacity: 1;
  width: 128rpx;
  margin-left: 0
}

/* ===== 指南模块 ===== */
.guide-links {
  display: flex;
  gap: 16rpx;
  margin: 0 28rpx 24rpx;
}

.guide-link {
  position: relative;
  flex: 1;
  padding: 28rpx 24rpx;
  border-radius: 32rpx;
  overflow: hidden;
}

.guide-link-copy {
  position: relative;
  z-index: 1;
}

.guide-link-title {
  font-size: 34rpx;
  line-height: 1.25;
  font-weight: 700;
  color: #2D2D2D;
}

.guide-link-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(45, 45, 45, 0.66);
}

.guide-link-deco {
  position: absolute;
  right: 20rpx;
  bottom: 10rpx;
  font-size: 70rpx;
  line-height: 1;
  opacity: 0.28;
}

.guide-link-cat {
  background: linear-gradient(145deg, #ECE6F9 0%, #E3DDF4 100%);
}

.guide-link-dog {
  background: linear-gradient(145deg, #DDF1EF 0%, #CFE8E4 100%);
}

/* ===== 代铲屎遛狗入口 ===== */
.care-entry-wrap {
  display: flex;
  align-items: center;
  margin: 0 28rpx 24rpx;
  padding: 28rpx 32rpx;
  background: linear-gradient(135deg, #FFF6EE 0%, #FDE8D8 100%);
  border-radius: 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(232, 135, 90, 0.12);
}

.care-entry-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.care-entry-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(232, 135, 90, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.care-entry-icon {
  font-size: 38rpx;
  line-height: 1;
}

.care-entry-text {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.care-entry-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2D2D2D;
  line-height: 1.3;
}

.care-entry-desc {
  font-size: 22rpx;
  color: rgba(45, 45, 45, 0.6);
  margin-top: 6rpx;
  line-height: 1.4;
}

.care-entry-tags {
  display: flex;
  gap: 8rpx;
  margin: 0 16rpx;
  flex-shrink: 0;
}

.care-tag {
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  line-height: 1.4;
}

.care-tag-helper {
  background: rgba(232, 135, 90, 0.12);
  color: #E8875A;
  border: 1rpx solid rgba(232, 135, 90, 0.4);
}

.care-tag-owner {
  background: rgba(142, 207, 201, 0.15);
  color: #3C6663;
  border: 1rpx solid rgba(142, 207, 201, 0.5);
}

.care-entry-arrow {
  font-size: 40rpx;
  color: rgba(45, 45, 45, 0.3);
  flex-shrink: 0;
  line-height: 1;
}

/* 上门沟通入口样式 */
.visit-entry-wrap {
  background: linear-gradient(135deg, #E8F5F4 0%, #CFE8E4 100%);
  box-shadow: 0 8rpx 32rpx rgba(142, 207, 201, 0.12);
}

/* ===== 提醒区域 ===== */
.reminders-section {
  margin-top: 8rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 24rpx;
  margin-bottom: 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
}

.section-more {
  font-size: 24rpx;
  color: #E8875A;
}

/* 提醒卡片 */
.reminder-card {
  display: flex;
  align-items: center;
}

.reminder-left {
  margin-right: 20rpx;
}

.reminder-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.reminder-content {
  flex: 1;
  min-width: 0;
}

.reminder-title {
  font-size: 28rpx;
  color: #2D2D2D;
  font-weight: 500;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reminder-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.reminder-type {
  flex-shrink: 0;
}

.reminder-date {
  font-size: 24rpx;
  color: #888888;
}

.reminder-countdown {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.countdown-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #6B2D1A;
}

.countdown-label {
  font-size: 20rpx;
  color: #888888;
}

/* 无提醒 */
.no-reminder {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
}

.no-reminder-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.no-reminder-text {
  font-size: 26rpx;
  color: #888888;
}
