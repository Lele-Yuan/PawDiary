.invite-page {
  min-height: 100vh;
}

/* ===== 加载状态 ===== */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
}

.loading-icon {
  font-size: 80rpx;
  color: #6B2D1A;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* ===== 邀请内容 ===== */
.invite-content {
  padding: 0 24rpx 120rpx;
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* ===== 宠物头像 ===== */
.pet-avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.pet-avatar-wrap {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #EDD9A3, #E8B4A2);
  box-shadow: 0 8rpx 24rpx rgba(232, 135, 90, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.pet-avatar {
  width: 100%;
  height: 100%;
}

.pet-avatar-placeholder {
  font-size: 80rpx;
  color: #FFFFFF;
  font-weight: 700;
}

/* ===== 宠物信息卡片 ===== */
.pet-info-card {
  padding: 40rpx 32rpx;
  border-radius: 32rpx;
  background-color: #FFFFFF;
  margin-bottom: 32rpx;
}

.pet-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.pet-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #313333;
}

.pet-tag {
  font-size: 22rpx;
  color: #E8875A;
  background-color: rgba(232, 135, 90, 0.12);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.pet-detail-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0EAD6;
}

.pet-detail-row:last-of-type {
  border-bottom: none;
}

.pet-label {
  font-size: 26rpx;
  color: #888888;
}

.pet-value {
  font-size: 28rpx;
  color: #2D2D2D;
  font-weight: 500;
}

.pet-desc {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.6;
}

/* ===== 操作按钮 ===== */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.action-btn {
  flex: 1;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  gap: 12rpx;
}

.join-btn {
  background: linear-gradient(135deg, #E8875A, #D4734A);
  color: #FFFFFF;
}

.cancel-btn {
  background-color: #F0EAD6;
  color: #6B2D1A;
}

.joined-btn {
  background-color: #E0E0E0;
  color: #AAAAAA;
}

.joined-btn[disabled] {
  opacity: 0.6;
}

.switch-btn {
  background-color: #6B2D1A;
  color: #FFFFFF;
}

.action-btn::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 28rpx;
}

.btn-hover {
  opacity: 0.85;
}

/* ===== 提示文案 ===== */
.invite-tip {
  padding: 0 24rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #888888;
  line-height: 1.6;
}

/* ===== 错误状态 ===== */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 0 24rpx;
}

.error-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 32rpx;
  color: #888888;
}
