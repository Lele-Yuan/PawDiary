.page-container {
  padding: 24rpx;
  padding-bottom: 140rpx;
  min-height: 100vh;
}

/* ===== 表单区块 ===== */
.form-section {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  background-color: #FFFFFF;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.form-group {
  margin-bottom: 28rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #313333;
  margin-bottom: 16rpx;
}

.required {
  color: #E8875A;
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  color: #313333;
  border-bottom: 1rpx solid #F0EAD6;
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #313333;
  border-bottom: 1rpx solid #F0EAD6;
  box-sizing: border-box;
  padding: 16rpx 0;
}

/* ===== 位置选择 ===== */
.location-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0EAD6;
}

.location-picker.readonly {
  background-color: #FAFAFA;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
}

.readonly-hint {
  font-size: 22rpx;
  color: #BBBBBB;
  flex-shrink: 0;
}

.location-info,
.location-placeholder {
  display: flex;
  align-items: center;
  flex: 1;
}

.location-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.location-address {
  font-size: 28rpx;
  color: #313333;
}

.location-hint {
  font-size: 28rpx;
  color: #BBBBBB;
}

.arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  flex-shrink: 0;
}

/* ===== 分类选择 ===== */
.category-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  border-radius: 60rpx;
  background-color: #F0EAD6;
  font-size: 26rpx;
  color: #6B2D1A;
}

.category-item.active {
  background: #6B2D1A;
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(107, 45, 26, 0.25);
}

.category-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.category-label {
  font-size: 26rpx;
}

/* ===== 图片上传 ===== */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.image-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #FFFFFF;
  font-size: 28rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #D5D0C5;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.add-icon {
  font-size: 48rpx;
  color: #CCCCCC;
}

.add-text {
  font-size: 22rpx;
  color: #BBBBBB;
  margin-top: 8rpx;
}

/* ===== 提交按钮 ===== */
.btn-section {
  margin-top: 40rpx;
  padding: 0 24rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #E8875A, #D4734A);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  text-align: center;
}

.submit-btn::after {
  border: none;
}

.btn-primary-hover {
  opacity: 0.85;
}
