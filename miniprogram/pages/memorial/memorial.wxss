.memorial-page {
  min-height: 100vh;
  background-color: #FBF9F7;
  padding-bottom: 80rpx;
}

/* ===== Tab 切换栏 ===== */
.tab-bar {
  display: flex;
  margin: 24rpx 32rpx 0;
  background-color: #F0EBE6;
  border-radius: 48rpx;
  padding: 6rpx;
  position: relative;
}

.tab-item {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #888888;
  padding: 18rpx 0;
  border-radius: 42rpx;
  position: relative;
  z-index: 1;
  transition: color 0.25s;
}

.tab-active {
  color: #6B2D1A;
  background-color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(107, 45, 26, 0.12);
}

/* ===== 我的纪念 Tab ===== */
.tab-content {
  padding: 32rpx;
}

/* 新增入口 */
.add-entry {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 2rpx dashed #D4B5A0;
}

.add-entry-icon {
  width: 64rpx;
  height: 64rpx;
  background-color: #FFF0E8;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #E8875A;
  font-weight: 300;
  line-height: 64rpx;
  text-align: center;
}

.add-entry-text {
  font-size: 28rpx;
  color: #E8875A;
  font-weight: 600;
}

/* 纪念卡片列表 */
.memorial-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.memorial-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.card-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  filter: grayscale(30%);
}

.card-candle {
  position: absolute;
  bottom: -4rpx;
  right: -4rpx;
  font-size: 28rpx;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.card-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #313333;
  margin-bottom: 8rpx;
}

.card-meta {
  display: block;
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 24rpx;
  color: #5E5F5D;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-blessing-count {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  background-color: #FFF0E8;
  border-radius: 16rpx;
  padding: 12rpx 20rpx;
}

.blessing-arrow {
  font-size: 24rpx;
  color: #E8875A;
  margin-top: 2rpx;
}

.blessing-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #E8875A;
}

.blessing-label {
  font-size: 20rpx;
  color: #888888;
}

/* 空状态 */
.my-empty,
.random-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 60rpx;
  gap: 16rpx;
}

.empty-emoji {
  font-size: 80rpx;
  line-height: 1;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #313333;
}

.empty-desc {
  font-size: 26rpx;
  color: #888888;
  text-align: center;
}

/* ===== 随机探访 Tab ===== */
/* 加载中 */
.loading-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  gap: 24rpx;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 4rpx solid #F0EBE6;
  border-top-color: #E8875A;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #888888;
}

/* 随机宠物卡片 */
.random-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(107, 45, 26, 0.08);
  margin-bottom: 24rpx;
}

.random-card-header {
  display: flex;
  gap: 28rpx;
  margin-bottom: 28rpx;
}

.random-avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.random-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  filter: grayscale(20%);
  border: 4rpx solid #F0EBE6;
}

.random-candle-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  font-size: 36rpx;
  line-height: 1;
}

.random-pet-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.random-pet-name {
  font-size: 44rpx;
  font-weight: 800;
  color: #313333;
  line-height: 1.2;
}

.random-pet-meta-row {
  display: flex;
  gap: 12rpx;
}

.random-meta-tag {
  font-size: 22rpx;
  color: #E8875A;
  background-color: #FFF0E8;
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}

.random-owner {
  font-size: 24rpx;
  color: #888888;
}

.random-pass-date {
  font-size: 24rpx;
  color: #AAAAAA;
}

/* 纪念寄语 */
.random-desc {
  background-color: #FBF9F7;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.random-desc-quote {
  font-size: 36rpx;
  color: #D4B5A0;
  line-height: 1;
  flex-shrink: 0;
}

.random-desc-text {
  font-size: 26rpx;
  color: #5E5F5D;
  line-height: 1.7;
  flex: 1;
}

/* 祝福统计 */
.blessing-stats {
  margin-bottom: 20rpx;
}

.blessing-stats-text {
  font-size: 24rpx;
  color: #888888;
}

/* 祝福列表 */
.blessing-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  border-top: 1rpx solid #F3EDE8;
  padding-top: 20rpx;
}

.blessing-item {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.blessing-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  flex-shrink: 0;
}

.blessing-body {
  flex: 1;
  background-color: #FBF9F7;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.blessing-nick {
  display: block;
  font-size: 22rpx;
  color: #888888;
  margin-bottom: 6rpx;
}

.blessing-content {
  font-size: 26rpx;
  color: #313333;
  line-height: 1.6;
}

/* 祝福输入区 */
.blessing-input-area {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 24rpx;
}

.blessing-textarea {
  width: 100%;
  font-size: 28rpx;
  color: #313333;
  min-height: 120rpx;
  max-height: 240rpx;
  line-height: 1.7;
}

.blessing-placeholder {
  color: #BBBBBB;
}

.blessing-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F3EDE8;
}

.blessing-counter {
  font-size: 22rpx;
  color: #AAAAAA;
}

.counter-warn {
  color: #E8875A;
}

.blessing-send-btn {
  background-color: #6B2D1A;
  border-radius: 40rpx;
  padding: 14rpx 40rpx;
}

.blessing-send-btn text,
.blessing-send-btn {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
}

.send-btn-disabled {
  opacity: 0.45;
}

/* 换一个按钮 */
.next-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F0EBE6;
  border-radius: 64rpx;
  height: 88rpx;
}

.next-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #6B2D1A;
  letter-spacing: 2rpx;
}
