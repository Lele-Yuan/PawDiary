<view class="profile-page">
  <nav-bar title="我的" titleOpacity="{{navTitleOpacity}}" />

  <!-- ===== 用户信息区 ===== -->
  <view class="user-section">
    <!-- 头像（圆角方形） -->
    <view class="user-avatar-wrap" bindtap="onLogin">
      <image
        class="user-avatar"
        src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}"
        mode="aspectFill"
        binderror="onAvatarError"
      />
    </view>
    <view class="memorial-float-btn" bindtap="goMemorial">
      <text class="memorial-float-icon">🕯️ 小天使🪽</text>
    </view>
    
    <view class="user-info-wrap">
      <!-- 游客态 -->
      <block wx:if="{{isGuest}}">
        <text class="user-name">游客</text>
        <view class="login-guide-btn" bindtap="onLogin">点击登录</view>
      </block>

      <!-- 已登录态 -->
      <block wx:else>
        <text class="user-name">{{userInfo.nickName}}</text>
        <view class="user-phone" wx:if="{{userInfo.phone}}">
          <text class="user-phone-text">{{userInfo.phone[0]}}{{userInfo.phone[1]}}{{userInfo.phone[2]}}****{{userInfo.phone[7]}}{{userInfo.phone[8]}}{{userInfo.phone[9]}}{{userInfo.phone[10]}}</text>
        </view>
        <!-- 微信云 badge -->
        <view class="cloud-badge">
          <text class="cloud-badge-icon">☁</text>
          <text class="cloud-badge-text">微信云已连接</text>
        </view>
      </block>
    </view>
  </view>

  <!-- ===== 常用功能 ===== -->
  <view class="quick-actions-section">
    <text class="quick-actions-title">常用功能</text>
    <view class="quick-actions-grid">
      <view class="quick-action-item" bindtap="goToCustomerService">
        <view class="quick-action-icon">💁</view>
        <text class="quick-action-label">客服反馈</text>
      </view>
      <view class="quick-action-item" bindtap="goDogGuide">
        <view class="quick-action-icon">📋</view>
        <text class="quick-action-label">养宠知识</text>
      </view>
    </view>
  </view>


  <!-- ===== 我的毛孩子 ===== -->
  <view class="family-section" wx:if="{{pets.length || true}}">
    <!-- 标题行 -->
    <view class="family-header">
      <view class="family-header-left">
        <text class="family-title">我的毛孩子</text>
        <text class="family-subtitle">{{pets.length}} 位成员</text>
      </view>
      <view class="family-add-btn" wx:if="{{isGuest}}" bindtap="onLogin">
        <text class="family-add-icon">+</text>
        <text class="family-add-text">添加宠物</text>
      </view>
      <view class="family-add-btn" wx:else bindtap="addPet">
        <text class="family-add-icon">+</text>
        <text class="family-add-text">添加宠物</text>
      </view>
    </view>

    <!-- 宠物卡片列表 -->
    <view
      class="family-pet-card {{item._id === currentPetId ? 'pet-card-selected' : 'pet-card-normal'}}"
      wx:for="{{pets}}"
      wx:key="_id"
      bindtap="onSwitchPet"
      data-pet-id="{{item._id}}"
    >
      <!-- 宠物头像 -->
      <image
        class="pet-card-avatar"
        src="{{item.avatar || '/images/default-avatar.png'}}"
        mode="aspectFill"
      />
      <!-- 宠物信息 -->
      <view class="pet-card-info">
        <view class="pet-card-name-row">
          <view class="pet-card-name">
            {{item.name}}
            <text class="pet-card-desc">{{item.age}}</text>
          </view>
          <text class="pet-role-tag pet-role-joined" wx:if="{{item.role !== 'creator'}}">已加入</text>
        </view>
        <text class="pet-card-desc">{{item.breed || '未知品种'}} · {{item.weight}}kg</text>
      </view>
      <!-- 编辑按钮 -->
      <view
        wx:if="{{ item._id === currentPetId && item.role === 'creator'}}"
        class="pet-card-edit {{item._id === currentPetId ? 'edit-btn-selected' : 'edit-btn-normal'}}"
        data-id="{{item._id}}"
        bindtap="editPet"
        catchtap
      >
        <text class="edit-icon">✎</text>
      </view>
    </view>

    <!-- 无宠物引导 -->
    <view class="family-empty" wx:if="{{!pets.length}}">
      <text class="family-empty-text">还没有添加宠物，快去添加吧</text>
    </view>
  </view>

  <!-- ===== Settings & Support ===== -->
  <view class="settings-section" hidden>
    <text class="settings-title">设置与支持</text>
    <view class="settings-group">

      <!-- 清除缓存 -->
      <view class="menu-item" bindtap="clearCache">
        <view class="menu-icon-circle">
          <text class="menu-icon-emoji">🔄</text>
        </view>
        <text class="menu-text">清除缓存</text>
        <text class="menu-arrow">›</text>
      </view>

      <!-- 关于我们 -->
      <view class="menu-item" bindtap="showAbout">
        <view class="menu-icon-circle">
          <text class="menu-icon-emoji">ℹ</text>
        </view>
        <text class="menu-text">关于宠物管家</text>
        <text class="menu-arrow">›</text>
      </view>

      <!-- 帮助中心 -->
      <view class="menu-item menu-item-last" bindtap="showHelp">
        <view class="menu-icon-circle">
          <text class="menu-icon-emoji">🎧</text>
        </view>
        <text class="menu-text">帮助中心</text>
        <text class="menu-arrow">›</text>
      </view>

    </view>
  </view>

  <!-- ===== 退出登录 ===== -->
  <view class="signout-section" wx:if="{{!isGuest}}">
    <view class="signout-pill" bindtap="onLogout">
      <text class="signout-text">退出登录</text>
    </view>
    <text class="version-text">VERSION 1.0.0</text>
  </view>

  <!-- 登录弹窗组件 -->
  <login-modal
    show="{{showLoginModal}}"
    avatarUrl="{{userInfo.avatarUrl}}"
    nickName="{{userInfo.nickName}}"
    phone="{{userInfo.phone}}"
    bind:success="onLoginSuccess"
    bind:close="onLoginClose"
  />

</view>
