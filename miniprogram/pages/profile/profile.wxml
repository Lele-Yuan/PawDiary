<view class="profile-page">
  <nav-bar title="我的" titleOpacity="{{navTitleOpacity}}" />

  <!-- ===== 用户信息区 ===== -->
  <view class="user-section">
    <!-- 头像（圆角方形） -->
    <view class="user-avatar-wrap" bindtap="onLogin">
      <image
        class="user-avatar"
        src="{{userInfo.avatarUrl || '/images/default/pet-avatar.png'}}"
        mode="aspectFill"
        binderror="onAvatarError"
      />
    </view>

    <!-- 游客态 -->
    <block wx:if="{{isGuest}}">
      <text class="user-name">游客</text>
      <view class="login-guide-btn" bindtap="onLogin">
        <text class="login-guide-text">点击登录</text>
      </view>
    </block>

    <!-- 已登录态 -->
    <block wx:else>
      <text class="user-name">{{userInfo.nickName}}</text>
      <view class="user-phone" wx:if="{{userInfo.phone}}">
        <text class="user-phone-text">{{userInfo.phone[0]}}{{userInfo.phone[1]}}{{userInfo.phone[2]}}****{{userInfo.phone[7]}}{{userInfo.phone[8]}}{{userInfo.phone[9]}}{{userInfo.phone[10]}}</text>
      </view>
      <!-- 微信云 badge -->
      <view class="cloud-badge">
        <text class="cloud-badge-icon">☁</text>
        <text class="cloud-badge-text">微信云已连接</text>
      </view>
    </block>
  </view>

  <!-- ===== 我的毛孩子 ===== -->
  <view class="family-section" wx:if="{{pets.length || true}}">
    <!-- 标题行 -->
    <view class="family-header">
      <view class="family-header-left">
        <text class="family-title">我的毛孩子</text>
        <text class="family-subtitle">{{pets.length}} 位成员</text>
      </view>
      <view class="family-add-btn" bindtap="addPet">
        <text class="family-add-icon">+</text>
        <text class="family-add-text">添加宠物</text>
      </view>
    </view>

    <!-- 宠物卡片列表 -->
    <view
      class="family-pet-card {{item._id === currentPetId ? 'pet-card-selected' : 'pet-card-normal'}}"
      wx:for="{{pets}}"
      wx:key="_id"
      bindtap="onSwitchPet"
      data-pet-id="{{item._id}}"
    >
      <!-- 宠物头像 -->
      <image
        class="pet-card-avatar"
        src="{{item.avatar || '/images/default/pet-avatar.png'}}"
        mode="aspectFill"
      />
      <!-- 宠物信息 -->
      <view class="pet-card-info">
        <view class="pet-card-name-row">
          <text class="pet-card-name">{{item.name}}</text>
          <text class="pet-role-tag pet-role-joined" wx:if="{{item.role !== 'creator'}}">已加入</text>
        </view>
        <text class="pet-card-desc">{{item.breed || '未知品种'}}{{item.age ? ' · ' + item.age + '岁' : ''}}</text>
      </view>
      <!-- 编辑按钮 -->
      <view
        wx:if="{{ item._id === currentPetId && item.role === 'creator'}}"
        class="pet-card-edit {{item._id === currentPetId ? 'edit-btn-selected' : 'edit-btn-normal'}}"
        data-id="{{item._id}}"
        bindtap="editPet"
        catchtap
      >
        <text class="edit-icon">✎</text>
      </view>
    </view>

    <!-- 无宠物引导 -->
    <view class="family-empty" wx:if="{{!pets.length}}">
      <text class="family-empty-text">还没有添加宠物，快去添加吧</text>
    </view>
  </view>

  <!-- ===== Settings & Support ===== -->
  <view class="settings-section">
    <text class="settings-title">设置与支持</text>
    <view class="settings-group">

      <!-- 清除缓存 -->
      <view class="menu-item" bindtap="clearCache">
        <view class="menu-icon-circle" style="background-color: #F5E6CC;">
          <text class="menu-icon-emoji">🔄</text>
        </view>
        <text class="menu-text">清除缓存</text>
        <text class="menu-arrow">›</text>
      </view>

      <!-- 提醒通知（展示用） -->
      <view class="menu-item">
        <view class="menu-icon-circle" style="background-color: #BEE3E7;">
          <text class="menu-icon-emoji">🔔</text>
        </view>
        <text class="menu-text">提醒通知</text>
        <text class="menu-arrow">›</text>
      </view>

      <!-- 语言 -->
      <view class="menu-item">
        <view class="menu-icon-circle" style="background-color: rgba(254,157,127,0.3);">
          <text class="menu-icon-emoji">🌐</text>
        </view>
        <text class="menu-text">语言设置</text>
        <text class="menu-value">中文</text>
        <text class="menu-arrow">›</text>
      </view>

      <!-- 关于我们 -->
      <view class="menu-item" bindtap="showAbout">
        <view class="menu-icon-circle" style="background-color: #E9E8E6;">
          <text class="menu-icon-emoji">ℹ</text>
        </view>
        <text class="menu-text">关于宠物管家</text>
        <text class="menu-arrow">›</text>
      </view>

      <!-- 帮助中心 -->
      <view class="menu-item menu-item-last">
        <view class="menu-icon-circle" style="background-color: rgba(190,235,231,0.4);">
          <text class="menu-icon-emoji">🎧</text>
        </view>
        <text class="menu-text">帮助中心</text>
        <text class="menu-arrow">›</text>
      </view>

    </view>
  </view>

  <!-- ===== 退出登录 ===== -->
  <view class="signout-section" wx:if="{{!isGuest}}">
    <view class="signout-pill" bindtap="onLogout">
      <text class="signout-text">退出登录</text>
    </view>
    <text class="version-text">VERSION 1.0.0</text>
  </view>

  <!-- 宠物列表弹窗（保留原有逻辑） -->
  <view class="modal-mask" wx:if="{{showPetList}}" bindtap="hidePetList">
    <view class="modal-content" catchtap>
      <view class="modal-title">我的宠物</view>
      <view class="pet-list-item" wx:for="{{pets}}" wx:key="_id">
        <image class="pet-list-avatar" src="{{item.avatar || '/images/default/pet-avatar.png'}}" mode="aspectFill" />
        <view class="pet-list-info">
          <text class="pet-list-name">{{item.name}}</text>
          <text class="pet-list-breed">{{item.breed || '未设置品种'}}</text>
        </view>
        <view class="pet-list-actions">
          <view class="action-btn edit" data-id="{{item._id}}" bindtap="editPet">编辑</view>
        </view>
      </view>
      <view class="add-pet-btn" bindtap="addPet">
        <text class="add-icon">+</text>
        <text>添加新宠物</text>
      </view>
      <view class="modal-close" bindtap="hidePetList">关闭</view>
    </view>
  </view>

  <!-- ===== 登录弹窗 ===== -->
  <view class="modal-mask" wx:if="{{showLoginModal}}" bindtap="closeLoginModal">
    <view class="login-modal" catchtap>
      <view class="login-modal-title">微信登录</view>
      <view class="login-modal-desc">完善您的个人信息，享受更好的体验</view>

      <!-- 头像选择 -->
      <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image class="avatar-preview" src="{{tempAvatarUrl || '/images/default/pet-avatar.png'}}" mode="aspectFill" />
        <view class="avatar-picker-hint">
          <text class="avatar-picker-text">{{tempAvatarUrl ? '重新选择头像' : '点击选择头像'}}</text>
        </view>
      </button>

      <!-- 昵称输入 -->
      <view class="login-field">
        <text class="login-field-label">昵称</text>
        <input
          class="login-field-input"
          type="nickname"
          placeholder="请输入昵称"
          bindinput="onNicknameInput"
          value="{{tempNickName}}"
        />
      </view>

      <!-- 手机号授权 -->
      <view class="login-field">
        <text class="login-field-label">手机号（可选）</text>
        <button
          class="phone-auth-btn {{tempPhone ? 'phone-authed' : ''}}"
          open-type="getPhoneNumber"
          bindgetphonenumber="onGetPhoneNumber"
        >
          <text wx:if="{{tempPhone}}">{{tempPhone[0]}}{{tempPhone[1]}}{{tempPhone[2]}}****{{tempPhone[7]}}{{tempPhone[8]}}{{tempPhone[9]}}{{tempPhone[10]}}</text>
          <text wx:else>点击授权手机号</text>
        </button>
      </view>

      <!-- 操作按钮 -->
      <view class="login-actions">
        <button class="login-confirm-btn" bindtap="confirmLogin">确认登录</button>
        <view class="login-cancel" bindtap="closeLoginModal">取消</view>
      </view>
    </view>
  </view>

</view>
