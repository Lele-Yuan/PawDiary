.profile-page {
  padding-bottom: 120rpx;
}

/* ===== 用户信息区 ===== */
.user-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx 40rpx;
}

.user-avatar-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 48rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  width: 112rpx;
  height: 112rpx;
}

.user-name {
  font-size: 60rpx;
  font-weight: 800;
  color: #313333;
  letter-spacing: -1rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

/* 微信云 badge */
.cloud-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: #BEE3E7;
  border-radius: 60rpx;
  padding: 8rpx 28rpx;
}

.cloud-badge-icon {
  font-size: 22rpx;
  color: #2E5956;
}

.cloud-badge-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #2E5956;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* ===== 游客态登录引导 ===== */
.login-guide-btn {
  background-color: #6B2D1A;
  border-radius: 60rpx;
  padding: 16rpx 56rpx;
  margin-top: 8rpx;
}

.login-guide-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

/* 已登录手机号 */
.user-phone {
  margin-bottom: 16rpx;
}

.user-phone-text {
  font-size: 26rpx;
  color: #888888;
  letter-spacing: 2rpx;
}

/* ===== 登录弹窗 ===== */
.login-modal {
  width: 100%;
  background-color: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 48rpx 40rpx 140rpx;
  max-height: 85vh;
  overflow-y: auto;
}

.login-modal-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #313333;
  text-align: center;
  margin-bottom: 12rpx;
}

.login-modal-desc {
  font-size: 26rpx;
  color: #888888;
  text-align: center;
  margin-bottom: 48rpx;
}

/* 头像选择器 */
.avatar-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: transparent;
  border: none;
  padding: 0;
  margin: 0 auto 40rpx;
  line-height: normal;
}

.avatar-picker::after {
  border: none;
}

.avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx dashed #B8B8C8;
  margin-bottom: 16rpx;
}

.avatar-picker-hint {
  display: flex;
  align-items: center;
}

.avatar-picker-text {
  font-size: 26rpx;
  color: #E8875A;
  font-weight: 500;
}

/* 登录表单字段 */
.login-field {
  margin-bottom: 32rpx;
}

.login-field-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #5E5F5D;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
}

.login-field-input {
  width: 100%;
  height: 88rpx;
  background-color: #F5F3F1;
  border-radius: 24rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #313333;
  box-sizing: border-box;
}

/* 手机号授权按钮 */
.phone-auth-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #F5F3F1;
  border-radius: 24rpx;
  font-size: 30rpx;
  color: #888888;
  text-align: center;
  border: none;
  padding: 0;
  margin: 0;
}

.phone-auth-btn::after {
  border: none;
}

.phone-auth-btn.phone-authed {
  background-color: rgba(190, 235, 231, 0.3);
  color: #2E5956;
  font-weight: 600;
}

/* 登录操作按钮 */
.login-actions {
  margin-top: 48rpx;
}

.login-confirm-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #6B2D1A;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
  text-align: center;
  border: none;
  margin-bottom: 24rpx;
}

.login-confirm-btn::after {
  border: none;
}

.login-cancel {
  text-align: center;
  color: #888888;
  font-size: 30rpx;
  padding: 16rpx 0;
}

/* ===== 我的毛孩子 ===== */
.family-section {
  padding: 0 32rpx;
  margin-bottom: 40rpx;
}

.family-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.family-header-left {
  display: flex;
  flex-direction: column;
}

.family-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #313333;
  margin-bottom: 4rpx;
}

.family-subtitle {
  font-size: 26rpx;
  color: #888888;
}

.family-add-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding-bottom: 4rpx;
}

.family-add-icon {
  font-size: 28rpx;
  color: #954931;
  font-weight: 700;
  line-height: 1;
}

.family-add-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #954931;
}

/* 宠物卡片通用 */
.family-pet-card {
  display: flex;
  align-items: center;
  border-radius: 64rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 16rpx;
}

.pet-card-normal {
  background-color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.pet-card-selected {
  background-color: rgba(190, 235, 231, 0.3);
  border: 4rpx dashed #BEE3E7;
}

.pet-card-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 64rpx;
  overflow: hidden;
  flex-shrink: 0;
  margin-right: 28rpx;
}

.pet-card-info {
  flex: 1;
  min-width: 0;
}

.pet-card-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #313333;
  margin-bottom: 6rpx;
}

.pet-card-desc {
  display: block;
  font-size: 24rpx;
  color: #5E5F5D;
}

.pet-card-edit {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
}

.edit-btn-normal {
  background-color: #F5F3F1;
}

.edit-btn-selected {
  background-color: rgba(255, 255, 255, 0.8);
}

.edit-icon {
  font-size: 28rpx;
  color: #5E5F5D;
}

.family-empty {
  padding: 32rpx;
  text-align: center;
}

.family-empty-text {
  font-size: 26rpx;
  color: #888888;
}

/* ===== 设置与支持 ===== */
.settings-section {
  padding: 0 32rpx;
  margin-bottom: 40rpx;
}

.settings-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #313333;
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

.settings-group {
  border-radius: 64rpx;
  overflow: hidden;
  padding: 8rpx 0;
  border-radius: 64rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #FFFFFF;
  border-bottom: 1px solid #E9E8E6;
}

.menu-item-last {
  margin-bottom: 8rpx;
  border-bottom: none;
}

.menu-icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.menu-icon-emoji {
  font-size: 36rpx;
  line-height: 1;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #313333;
}

.menu-value {
  font-size: 26rpx;
  color: #888888;
  margin-right: 8rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: #B1B2B0;
  font-weight: 300;
}

/* ===== 退出登录 ===== */
.signout-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 32rpx 80rpx;
}

.signout-pill {
  background-color: #E9E8E6;
  border-radius: 60rpx;
  padding: 20rpx 80rpx;
  margin-bottom: 28rpx;
}

.signout-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #5E5F5D;
}

.version-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #B1B2B0;
  letter-spacing: 2rpx;
  text-transform: uppercase;
}

/* ===== 宠物列表弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background-color: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 32rpx 140rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #313333;
  text-align: center;
  margin-bottom: 32rpx;
}

.pet-list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 16rpx;
  background-color: #F5F0E8;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.pet-list-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.pet-list-info {
  flex: 1;
  min-width: 0;
}

.pet-list-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D2D2D;
  display: block;
}

.pet-list-breed {
  font-size: 24rpx;
  color: #888888;
  display: block;
  margin-top: 4rpx;
}

.pet-list-actions {
  flex-shrink: 0;
}

.action-btn {
  padding: 8rpx 24rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.action-btn.edit {
  background-color: rgba(107, 45, 26, 0.1);
  color: #6B2D1A;
}

.add-pet-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border: 3rpx dashed #B8B8C8;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #888888;
}

.add-pet-btn .add-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

.modal-close {
  text-align: center;
  color: #888888;
  font-size: 30rpx;
  padding: 24rpx 0 8rpx;
}
