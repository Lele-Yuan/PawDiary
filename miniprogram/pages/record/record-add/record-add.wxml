<nav-bar title="{{pageTitle}}" back="{{true}}" />

<view class="page-container">
  <!-- 记录类型选择 -->
  <view class="form-section card">
    <view class="form-label">记录类型 <text class="required">*</text></view>
    <picker mode="selector" disabled range="{{typeList}}" range-key="label" value="{{typeIndex}}" bindchange="onSelectType">
      <view class="form-picker">
        <text class="{{typeIndex !== null ? '' : 'placeholder'}}">{{typeIndex !== null ? typeList[typeIndex].label : '请选择记录类型'}}</text>
        <text class="arrow">›</text>
      </view>
    </picker>
  </view>

  <!-- 表单区域 -->
  <view class="form-section card">
    <!-- 日期 -->
    <view class="form-group">
      <view class="form-label">日期 <text class="required">*</text></view>
      <picker mode="date" value="{{form.date}}" end="{{today}}" bindchange="onDateChange" data-field="date">
        <view class="form-picker">
          <text class="{{form.date ? '' : 'placeholder'}}">{{form.date || '请选择日期'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 发情类型：发情阶段选择 -->
    <view class="form-group" wx:if="{{form.type === 'heat'}}">
      <view class="form-label">发情阶段</view>
      <picker mode="selector" range="{{heatStageOptions}}" range-key="label" value="{{heatStageIndex}}" bindchange="onHeatStageChange">
        <view class="form-picker">
          <text class="{{heatStageIndex !== null ? '' : 'placeholder'}}">{{heatStageIndex !== null ? heatStageOptions[heatStageIndex].label : '请选择发情阶段'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 标题（根据类型显示或隐藏） -->
    <view class="form-group" wx:if="{{!hideTitle}}">
      <view class="form-label">{{titlePlaceholder}}</view>
      <input
        class="form-input"
        placeholder="{{titlePlaceholder}}"
        value="{{form.title}}"
        bindinput="onInputChange"
        data-field="title"
        maxlength="50"
      />
    </view>

    <!-- 体重类型：体重输入框 + 单位选择 -->
    <view class="form-group" wx:if="{{form.type === 'weight'}}">
      <view class="form-label">体重</view>
      <view class="input-with-unit">
        <input
          class="form-input"
          type="digit"
          placeholder="请输入体重"
          value="{{form.weight}}"
          bindinput="onInputChange"
          data-field="weight"
        />
        <picker mode="selector" range="{{weightUnits}}" range-key="label" value="{{weightUnitIndex}}" bindchange="onWeightUnitChange">
          <view class="unit-picker">
            <text>{{weightUnits[weightUnitIndex].label}}</text>
            <text class="arrow">›</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- 尿便类型：选择框（正常/异常），异常时需要输入框填写异常描述 -->
    <view class="form-group" wx:if="{{form.type === 'poop'}}">
      <view class="form-label">状态</view>
      <picker mode="selector" range="{{poopStatuses}}" range-key="label" value="{{poopStatusIndex}}" bindchange="onPoopStatusChange">
        <view class="form-picker">
          <text class="{{poopStatusIndex !== null ? '' : 'placeholder'}}">{{poopStatusIndex !== null ? poopStatuses[poopStatusIndex].label : '请选择状态'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-group" wx:if="{{form.type === 'poop' && isPoopAbnormal}}">
      <view class="form-label">异常描述</view>
      <textarea
        class="form-textarea"
        placeholder="请描述异常情况..."
        value="{{form.abnormalDesc}}"
        bindinput="onInputChange"
        data-field="abnormalDesc"
        maxlength="200"
        auto-height
      />
    </view>

    <!-- 喝水：输入框 + 单位ml -->
    <view class="form-group" wx:if="{{form.type === 'water'}}">
      <view class="form-label">饮水量</view>
      <view class="input-with-unit">
        <input
          class="form-input"
          type="digit"
          placeholder="请输入饮水量"
          value="{{form.waterAmount}}"
          bindinput="onInputChange"
          data-field="waterAmount"
        />
        <text class="unit-label">ml</text>
      </view>
    </view>

    <!-- 饮食类型：食物类型选择框 + 进食量输入框 -->
    <view class="form-group" wx:if="{{form.type === 'diet'}}">
      <view class="form-label">食物类型</view>
      <picker mode="selector" range="{{foodTypes}}" range-key="label" value="{{foodTypeIndex}}" bindchange="onFoodTypeChange">
        <view class="form-picker">
          <text class="{{foodTypeIndex !== null ? '' : 'placeholder'}}">{{foodTypeIndex !== null ? foodTypes[foodTypeIndex].label : '请选择食物类型'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-group" wx:if="{{form.type === 'diet'}}">
      <view class="form-label">进食量</view>
      <input
        class="form-input"
        type="digit"
        placeholder="请输入进食量"
        value="{{form.foodAmount}}"
        bindinput="onInputChange"
        data-field="foodAmount"
      />
    </view>

    <!-- 驱虫类型：驱虫类型选择框 -->
    <view class="form-group" wx:if="{{form.type === 'deworm'}}">
      <view class="form-label">驱虫类型</view>
      <picker mode="selector" range="{{dewormTypes}}" range-key="label" value="{{dewormTypeIndex}}" bindchange="onDewormTypeChange">
        <view class="form-picker">
          <text class="{{dewormTypeIndex !== null ? '' : 'placeholder'}}">{{dewormTypeIndex !== null ? dewormTypes[dewormTypeIndex].label : '请选择驱虫类型'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 疫苗类型：疫苗类型选择框 -->
    <view class="form-group" wx:if="{{form.type === 'vaccine'}}">
      <view class="form-label">疫苗类型</view>
      <picker mode="selector" range="{{vaccineTypes}}" range-key="label" value="{{vaccineTypeIndex}}" bindchange="onVaccineTypeChange">
        <view class="form-picker">
          <text class="{{vaccineTypeIndex !== null ? '' : 'placeholder'}}">{{vaccineTypeIndex !== null ? vaccineTypes[vaccineTypeIndex].label : '请选择疫苗类型'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 给药类型（原看病）：给药方式选择框 + 剂量输入框 -->
    <view class="form-group" wx:if="{{form.type === 'illness'}}">
      <view class="form-label">给药方式</view>
      <picker mode="selector" range="{{medicationTypes}}" range-key="label" value="{{medicationTypeIndex}}" bindchange="onMedicationTypeChange">
        <view class="form-picker">
          <text class="{{medicationTypeIndex !== null ? '' : 'placeholder'}}">{{medicationTypeIndex !== null ? medicationTypes[medicationTypeIndex].label : '请选择给药方式'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-group" wx:if="{{form.type === 'illness'}}">
      <view class="form-label">剂量</view>
      <input
        class="form-input"
        type="digit"
        placeholder="请输入剂量"
        value="{{form.dosage}}"
        bindinput="onInputChange"
        data-field="dosage"
      />
    </view>

    <!-- 体检类型：医院名称输入框 -->
    <view class="form-group" wx:if="{{form.type === 'checkup'}}">
      <view class="form-label">医院名称</view>
      <input
        class="form-input"
        placeholder="请输入医院名称"
        value="{{form.hospitalName}}"
        bindinput="onInputChange"
        data-field="hospitalName"
        maxlength="50"
      />
    </view>

    <!-- 详细描述 -->
    <view class="form-group">
      <view class="form-label">详细描述</view>
      <textarea
        class="form-textarea"
        placeholder="记录详细情况..."
        value="{{form.description}}"
        bindinput="onInputChange"
        data-field="description"
        maxlength="500"
        auto-height
      />
    </view>
    <!-- 提醒开关 -->
    <view class="form-group remind-row">
      <view class="form-label">下次提醒</view>
      <switch checked="{{form.enableRemind}}" bindchange="onRemindChange" color="#6B2D1A" />
    </view>

    <!-- 下次预计日期 -->
    <view class="form-group" wx:if="{{form.enableRemind}}">
      <view class="form-label">下次预计日期</view>
      <picker mode="date" value="{{form.nextDate}}" start="{{today}}" bindchange="onDateChange" data-field="nextDate">
        <view class="form-picker">
          <text class="{{form.nextDate ? '' : 'placeholder'}}">{{form.nextDate || '选填，用于到期提醒'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 间隔选择（仅提醒开启时显示） -->
    <view class="interval-section" wx:if="{{form.enableRemind}}">
      <view class="form-label">提醒间隔</view>
      <view class="interval-tags">
        <view class="interval-tag {{form.remindInterval === 30 ? 'active' : ''}}"
          data-days="30" bindtap="onSelectInterval">30天</view>
        <view class="interval-tag {{form.remindInterval === 60 ? 'active' : ''}}"
          data-days="60" bindtap="onSelectInterval">60天</view>
        <view class="interval-tag {{form.remindInterval === 90 ? 'active' : ''}}"
          data-days="90" bindtap="onSelectInterval">90天</view>
        <view class="interval-tag {{form.remindInterval === 180 ? 'active' : ''}}"
          data-days="180" bindtap="onSelectInterval">180天</view>
      </view>
      <view class="interval-custom">
        <input class="interval-input" type="number" placeholder="自定义天数"
          value="{{customInterval}}" bindinput="onCustomInterval" />
        <text class="interval-unit">天</text>
      </view>
      <view class="next-date-preview" wx:if="{{form.nextDate}}">
        <text class="preview-icon">📅</text>
        <text class="preview-text">下次提醒：{{form.nextDate}}</text>
      </view>
    </view>
  </view>

  <!-- 图片上传 -->
  <view class="form-section card">
    <view class="form-label">图片（最多9张）</view>
    <view class="image-grid">
      <view class="image-item" wx:for="{{form.images}}" wx:key="index">
        <image class="preview-img" src="{{item}}" mode="aspectFill" />
        <view class="image-delete" data-index="{{index}}" bindtap="deleteImage">×</view>
      </view>
      <view class="image-add" wx:if="{{form.images.length < 9}}" bindtap="chooseImage">
        <text class="add-icon">+</text>
        <text class="add-text">添加图片</text>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="btn-section">
    <button
      class="btn-primary submit-btn"
      hover-class="btn-primary-hover"
      bindtap="onSubmit"
      loading="{{submitting}}"
    >
      {{editId ? '保存修改' : '保存记录'}}
    </button>
    <button
      class="btn-delete"
      wx:if="{{editId}}"
      hover-class="btn-delete-hover"
      bindtap="onDelete"
    >删除记录</button>
  </view>
</view>
