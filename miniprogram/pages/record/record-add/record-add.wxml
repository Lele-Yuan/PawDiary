<nav-bar title="{{pageTitle}}" back="{{true}}" />

<view class="page-container">
  <!-- 记录类型选择 -->
  <view class="form-section card">
    <view class="form-label">记录类型 <text class="required">*</text></view>
    <view class="type-selector">
      <view
        class="type-item {{form.type === item.key ? 'active' : ''}}"
        wx:for="{{typeList}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onSelectType"
      >
        <text class="type-icon">{{item.icon}}</text>
        <text class="type-label">{{item.label}}</text>
      </view>
    </view>
  </view>

  <!-- 表单区域 -->
  <view class="form-section card">
    <!-- 日期 -->
    <view class="form-group">
      <view class="form-label">日期 <text class="required">*</text></view>
      <picker mode="date" value="{{form.date}}" end="{{today}}" bindchange="onDateChange" data-field="date">
        <view class="form-picker">
          <text class="{{form.date ? '' : 'placeholder'}}">{{form.date || '请选择日期'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 标题 -->
    <view class="form-group">
      <view class="form-label">标题 <text class="required">*</text></view>
      <input
        class="form-input"
        placeholder="如：体内驱虫-大宠爱"
        value="{{form.title}}"
        bindinput="onInputChange"
        data-field="title"
        maxlength="50"
      />
    </view>

    <!-- 详细描述 -->
    <view class="form-group">
      <view class="form-label">详细描述</view>
      <textarea
        class="form-textarea"
        placeholder="记录详细情况..."
        value="{{form.description}}"
        bindinput="onInputChange"
        data-field="description"
        maxlength="500"
        auto-height
      />
    </view>

    <!-- 地点 -->
    <view class="form-group">
      <view class="form-label">地点</view>
      <input
        class="form-input"
        placeholder="如：xxx宠物医院"
        value="{{form.location}}"
        bindinput="onInputChange"
        data-field="location"
        maxlength="50"
      />
    </view>

    <!-- 花费 -->
    <view class="form-group">
      <view class="form-label">花费（元）</view>
      <input
        class="form-input"
        type="digit"
        placeholder="请输入花费金额"
        value="{{form.cost}}"
        bindinput="onInputChange"
        data-field="cost"
      />
    </view>

    <!-- 下次预计日期 -->
    <view class="form-group" wx:if="{{!form.enableRemind}}">
      <view class="form-label">下次预计日期</view>
      <picker mode="date" value="{{form.nextDate}}" start="{{today}}" bindchange="onDateChange" data-field="nextDate">
        <view class="form-picker">
          <text class="{{form.nextDate ? '' : 'placeholder'}}">{{form.nextDate || '选填，用于到期提醒'}}</text>
          <text class="arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 提醒开关 -->
    <view class="form-group remind-row">
      <view class="form-label">下次提醒</view>
      <switch checked="{{form.enableRemind}}" bindchange="onRemindChange" color="#6B2D1A" />
    </view>

    <!-- 间隔选择（仅提醒开启时显示） -->
    <view class="interval-section" wx:if="{{form.enableRemind}}">
      <view class="form-label">提醒间隔</view>
      <view class="interval-tags">
        <view class="interval-tag {{form.remindInterval === 30 ? 'active' : ''}}"
          data-days="30" bindtap="onSelectInterval">30天</view>
        <view class="interval-tag {{form.remindInterval === 60 ? 'active' : ''}}"
          data-days="60" bindtap="onSelectInterval">60天</view>
        <view class="interval-tag {{form.remindInterval === 90 ? 'active' : ''}}"
          data-days="90" bindtap="onSelectInterval">90天</view>
        <view class="interval-tag {{form.remindInterval === 180 ? 'active' : ''}}"
          data-days="180" bindtap="onSelectInterval">180天</view>
      </view>
      <view class="interval-custom">
        <input class="interval-input" type="number" placeholder="自定义天数"
          value="{{customInterval}}" bindinput="onCustomInterval" />
        <text class="interval-unit">天</text>
      </view>
      <view class="next-date-preview" wx:if="{{form.nextDate}}">
        <text class="preview-icon">📅</text>
        <text class="preview-text">下次提醒：{{form.nextDate}}</text>
      </view>
    </view>
  </view>

  <!-- 图片上传 -->
  <view class="form-section card">
    <view class="form-label">图片（最多9张）</view>
    <view class="image-grid">
      <view class="image-item" wx:for="{{form.images}}" wx:key="index">
        <image class="preview-img" src="{{item}}" mode="aspectFill" />
        <view class="image-delete" data-index="{{index}}" bindtap="deleteImage">×</view>
      </view>
      <view class="image-add" wx:if="{{form.images.length < 9}}" bindtap="chooseImage">
        <text class="add-icon">+</text>
        <text class="add-text">添加图片</text>
      </view>
    </view>
  </view>

  <!-- 提交按钮 -->
  <view class="btn-section">
    <button
      class="btn-primary submit-btn"
      hover-class="btn-primary-hover"
      bindtap="onSubmit"
      loading="{{submitting}}"
    >
      {{editId ? '保存修改' : '保存记录'}}
    </button>
    <button
      class="btn-delete"
      wx:if="{{editId}}"
      hover-class="btn-delete-hover"
      bindtap="onDelete"
    >删除记录</button>
  </view>
</view>