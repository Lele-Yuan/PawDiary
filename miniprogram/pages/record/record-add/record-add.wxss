.page-container {
  padding-bottom: 60rpx;
}

.form-section {
  margin-top: 16rpx;
}

.required {
  color: #C0392B;
  margin-left: 4rpx;
}

/* 类型选择器 */
.type-selector {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.type-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background-color: #F5F0E8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.type-item.active {
  background-color: rgba(107, 45, 26, 0.1);
  border-color: #6B2D1A;
}

.type-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.type-label {
  font-size: 24rpx;
  color: #6B6B80;
}

.type-item.active .type-label {
  color: #6B2D1A;
  font-weight: 500;
}

/* 图片网格 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.image-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.image-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #C0392B;
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 28rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  line-height: 1;
}

.image-add {
  width: 180rpx;
  height: 180rpx;
  border: 3rpx dashed #CCCCCC;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.image-add .add-icon {
  font-size: 48rpx;
  color: #CCCCCC;
  line-height: 1;
}

.image-add .add-text {
  font-size: 22rpx;
  color: #CCCCCC;
  margin-top: 8rpx;
}

/* 提交按钮 */
.btn-section {
  padding: 32rpx 24rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  font-size: 32rpx;
}