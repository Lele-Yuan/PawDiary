.type-select-page {
  padding: 24rpx;
  padding-bottom: 40rpx;
}

.category-section {
  margin-bottom: 40rpx;
}

.category-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 20rpx;
  padding-left: 8rpx;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.type-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 16rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.2s ease;
}

.type-card:active {
  background-color: #F5F0E8;
  border-color: #E8875A;
  transform: scale(0.95);
}

.card-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.card-label {
  font-size: 24rpx;
  color: #6B6B80;
  text-align: center;
}
