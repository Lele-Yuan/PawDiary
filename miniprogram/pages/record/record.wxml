<view class="record-page">
  <nav-bar title="日常记录" titleOpacity="{{navTitleOpacity}}" />

  <!-- 加载中 -->
  <loading-view wx:if="{{!loaded}}" />

  <!-- 当前宠物 -->
  <view class="top-bar">
    <view class="current-pet" wx:if="{{currentPetName}}">
      <text class="pet-tag">🐾 {{currentPetName}}</text>
    </view>
  </view>
  <!-- 标签筛选栏 -->
  <scroll-view class="type-tabs" scroll-x enable-flex>
    <view
      class="tab-item {{activeType === item.key ? 'active' : ''}}"
      wx:for="{{typeList}}"
      wx:key="key"
      data-type="{{item.key}}"
      bindtap="switchType"
    >
      <text class="tab-label">{{item.label}}</text>
    </view>
  </scroll-view>

  <!-- 节标题 -->
  <view class="section-title-row" wx:if="{{records.length}}">
    <text class="section-title">健康时间线</text>
  </view>

  <!-- 时间线记录列表 -->
  <view class="timeline" wx:if="{{records.length}}">
    <view class="timeline-item" wx:for="{{records}}" wx:key="_id">
      <!-- 左侧时间线 -->
      <view class="timeline-left">
        <view class="timeline-date">
          <text class="date-text">{{item.shortDateStr}}</text>
          <text class="hour-text" wx:if="{{item.hour}}">{{item.hourStr}}</text>
        </view>
        <!-- upcoming 标签 -->
        <view class="upcoming-tag" wx:if="{{item.nextDateStr}}">即将到来</view>
        <view class="timeline-dot" style="background-color: {{item.typeColor}};"></view>
        <view class="timeline-line" wx:if="{{index < records.length - 1}}"></view>
      </view>

      <!-- 右侧卡片 -->
      <view
        class="timeline-card {{item.nextDateStr ? 'card-upcoming' : 'card-completed'}}"
        data-id="{{item._id}}"
        bindtap="goEdit"
        bindlongpress="onLongPressRecord"
      >

        <!-- 主内容行：图标圆 + 内容 -->
        <view class="card-main">
          <!-- 类型图标圆形 -->
          <view class="card-icon-circle" style="background-color: {{item.typeColor}}22;">
            <text wx:if="{{item.type === 'weight'}}">⚖️</text>
            <text wx:elif="{{item.type === 'poop'}}">💩</text>
            <text wx:elif="{{item.type === 'diet'}}">🍖</text>
            <text wx:elif="{{item.type === 'water'}}">💧</text>
            <text wx:elif="{{item.type === 'deworm'}}">🐜</text>
            <text wx:elif="{{item.type === 'vaccine'}}">💉</text>
            <text wx:elif="{{item.type === 'checkup'}}">🩺</text>
            <text wx:elif="{{item.type === 'illness'}}">🏥</text>
            <text wx:elif="{{item.type === 'bath'}}">🛁</text>
            <text wx:elif="{{item.type === 'nail'}}">💅</text>
            <text wx:elif="{{item.type === 'ear'}}">👂</text>
            <text wx:elif="{{item.type === 'paw'}}">🐾</text>
            <text wx:elif="{{item.type === 'gland'}}">💉</text>
            <text wx:elif="{{item.type === 'teeth'}}">🦷</text>
            <text wx:elif="{{item.type === 'beauty'}}">✂️</text>
            <text wx:elif="{{item.type === 'disinfect'}}">🧴</text>
            <text wx:elif="{{item.type === 'litter'}}">🏝️</text>
            <text wx:elif="{{item.type === 'toy'}}">🧸</text>
            <text wx:elif="{{item.type === 'cage'}}">🏠</text>
            <text wx:else>⚠️</text>
          </view>

          <!-- 文字内容 -->
          <view class="card-content">
            <view class="card-title-row">
              <text class="card-title">{{item.title}}</text>
              <text class="remind-icon" wx:if="{{item.hasRemind}}">🔔</text>


              <!-- upcoming 操作行 -->
              <button
                class="complete-btn"
                size="mini"
                hover-class="complete-btn-hover"
                data-id="{{item._id}}"
                data-type="{{item.type}}"
                data-title="{{item.title}}"
                data-enable-remind="{{item.enableRemind}}"
                data-remind-interval="{{item.remindInterval}}"
                catchtap="onCompleteRecord"
              >立即完成</button>
            </view>
            <!-- upcoming 副文字 -->
            <text class="card-subtitle subtitle-upcoming" wx:if="{{item.nextDateStr}}">下次：{{item.nextDateStr}}</text>
            <!-- completed 副文字 -->
            <text class="card-subtitle subtitle-completed" wx:else>已完成</text>
            <!-- 图片 -->
            <view class="card-images" wx:if="{{item.images && item.images.length}}">
              <image
                class="thumb-img"
                wx:for="{{item.images}}"
                wx:for-item="img"
                wx:for-index="imgIdx"
                wx:key="imgIdx"
                src="{{img}}"
                mode="aspectFill"
                data-urls="{{item.images}}"
                data-current="{{img}}"
                bindtap="previewImage"
              />
            </view>
            <!-- 提醒倒计时进度条 -->
            <view class="remind-bar" wx:if="{{item.hasRemind}}">
              <view class="remind-progress-track">
                <view class="remind-progress-fill" style="width: {{item.remindProgress}}%; background-color: {{item.remindProgressColor}};"></view>
              </view>
              <text class="remind-days-text {{item.remindOverdue ? 'overdue' : ''}}">{{item.remindDaysText}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <empty-state
    wx:if="{{!records.length && loaded}}"
    icon="📝"
    title="还没有记录"
    description="记录毛孩子的每次驱虫、体检、疫苗和洗澡吧"
    btnText="添加记录"
    bind:action="goAdd"
    canEdit="{{canEdit}}"
  />

  <!-- 悬浮添加按钮 -->
  <view class="fab-btn" hover-class="fab-btn-hover" bindtap="goAdd" wx:if="{{canEdit}}">+</view>
</view>
