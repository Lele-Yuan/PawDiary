.record-page {
  padding-bottom: 140rpx;
}

/* ===== 标签筛选栏 ===== */
.type-tabs {
  display: flex;
  white-space: nowrap;
  padding: 20rpx 28rpx;
  width: auto;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 36rpx;
  margin-right: 16rpx;
  border-radius: 60rpx;
  font-size: 26rpx;
  color: #6B2D1A;
  background-color: #F0EAD6;
  flex-shrink: 0;
  height: 32rpx;
}

.tab-item.active {
  background: #6B2D1A;
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(107, 45, 26, 0.25);
}

/* ===== 节标题 ===== */
.section-title-row {
  padding: 32rpx 32rpx 8rpx;
}

.section-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #313333;
  letter-spacing: -1rpx;
}

/* ===== 时间线容器 ===== */
.timeline {
  padding: 16rpx 24rpx 24rpx 0;
}

.timeline-item {
  display: flex;
  min-height: 120rpx;
}

.timeline-left {
  width: 72rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.timeline-dot {
  opacity: 0.5;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-top: 40rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.timeline-line {
  width: 3rpx;
  flex: 1;
  background-color: #E8E2D8;
  margin: 8rpx 0;
}

/* ===== 卡片通用 ===== */
.timeline-card {
  flex: 1;
  border-radius: 64rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
}

/* upcoming：白底右上角渐变 */
.card-upcoming {
  background: linear-gradient(135deg, #FFFFFF 60%, rgba(232, 135, 90, 0.08) 100%);
  box-shadow: 0 8rpx 32rpx rgba(149, 73, 49, 0.07);
}

/* completed：灰底 */
.card-completed {
  background-color: #F5F3F1;
}

/* ===== 即将到来标签 ===== */
.upcoming-tag {
  display: inline-block;
  background-color: #FE9D7F;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

/* ===== 主内容行 ===== */
.card-main {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
}

/* 类型图标圆形 */
.card-icon-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

/* 文字内容区 */
.card-content {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #313333;
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.card-subtitle {
  font-size: 24rpx;
  display: block;
  margin-bottom: 8rpx;
}

.subtitle-upcoming {
  color: #5E5F5D;
}

.subtitle-completed {
  color: #888888;
}

.card-details {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.detail-item {
  font-size: 24rpx;
  color: #888888;
}

/* ===== 操作行（upcoming） ===== */
.card-actions {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  gap: 16rpx;
}

.complete-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #6B2D1A;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 40rpx;
  text-align: center;
  border: none;
}

.complete-btn::after {
  border: none;
}

.complete-btn-hover {
  opacity: 0.85;
}

.bell-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #F5F3F1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

/* ===== 图片预览 ===== */
.card-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.thumb-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
}
