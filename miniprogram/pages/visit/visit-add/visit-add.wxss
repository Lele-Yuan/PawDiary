.add-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ===================== 无权限 ===================== */
.no-permission {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}
.no-perm-icon { font-size: 96rpx; margin-bottom: 24rpx; }
.no-perm-text { font-size: 32rpx; color: #333; font-weight: 600; margin-bottom: 12rpx; }
.no-perm-sub { font-size: 26rpx; color: #999; }

/* ===================== 滚动容器 ===================== */
.form-scroll {
  flex: 1;
  padding-bottom: 40rpx;
}

/* ===================== 状态栏 ===================== */
.status-bar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 16rpx;
}
.status-label-text { font-size: 26rpx; color: #666; }
.status-tag {
  font-size: 22rpx;
  color: #fff;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}
.confirm-marks { display: flex; gap: 16rpx; margin-left: auto; }
.confirm-mark { font-size: 22rpx; color: #bbb; }
.confirm-mark.confirmed { color: #5BC47A; }

/* ===================== 表单区块 ===================== */
.form-section {
  background: #ffffff80;
  border-radius: 20rpx;
  margin: 0 24rpx 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}
.section-hint {
  font-size: 22rpx;
  color: #999;
  font-weight: 400;
  margin-left: 12rpx;
}
.private-hint { color: #888; }

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.section-title-row .section-title { margin-bottom: 0; }

.checkin-progress {
  font-size: 24rpx;
  color: #5B8DEF;
  background: #EBF2FF;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.add-btn {
  font-size: 26rpx;
  color: #E8875A;
  padding: 6rpx 16rpx;
  border: 1rpx solid #E8875A;
  border-radius: 20rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
  text-align: center;
  padding: 20rpx 0;
}

/* ===================== 表单控件 ===================== */
.form-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f0eb;
}
.form-item:last-child { border-bottom: none; }

.form-label {
  font-size: 26rpx;
  color: #666;
  width: 180rpx;
  flex-shrink: 0;
}

.my-tag {
  font-size: 22rpx;
  color: #E8875A;
  font-weight: 500;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.form-role-section .form-input {
  text-align: right;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* ===================== 角色选择 ===================== */
.role-select-row {
  display: flex;
  gap: 20rpx;
}

.role-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 16rpx;
  border: 2rpx solid #ffffff80;
  border-radius: 16rpx;
  transition: all 0.2s;
}
.role-card-active {
  border-color: #E8875A;
}
.role-icon { font-size: 48rpx; margin-bottom: 12rpx; }
.role-name { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 6rpx; }
.role-desc { font-size: 22rpx; color: #999; }

/* ===================== 上门时间 ===================== */
.time-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f0eb;
  transition: opacity 0.15s;
}
.time-row:last-of-type { border-bottom: none; }

.time-row-done {
  opacity: 0.6;
}

.time-row-dragging {
  opacity: 0.35;
}

.time-row-drag-target {
  border-top: 3rpx solid #E8875A;
}

.drag-handle {
  font-size: 32rpx;
  color: #ccc;
  padding: 0 8rpx 0 0;
  flex-shrink: 0;
  cursor: grab;
  user-select: none;
}

.time-picker-btn {
  flex: 1;
  background: #f9f5f1;
  border-radius: 10rpx;
  padding: 14rpx 16rpx;
  font-size: 26rpx;
  color: #555;
  text-align: center;
}

.time-picker-btn-done {
  background: #f0f0f0;
  color: #aaa;
  text-decoration: line-through;
}

.time-done-tag {
  font-size: 22rpx;
  border-radius: 20rpx;
  padding: 4rpx 14rpx;
  white-space: nowrap;
  flex-shrink: 0;
  border: 1rpx solid;
}

.time-done-tag-serving {
  color: #9B7FE8;
  border-color: #9B7FE8;
}

.time-done-tag-completed {
  color: #5BC47A;
  border-color: #5BC47A;
}

.remove-btn {
  font-size: 36rpx;
  color: #ccc;
  padding: 0 8rpx;
  line-height: 1;
}

/* ===================== 位置 ===================== */
.location-choose-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #f9f5f1;
  padding: 20rpx 24rpx;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #E8875A;
  margin-bottom: 16rpx;
}
.location-icon { font-size: 30rpx; }

.location-address {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f0eb;
}
.addr-tag { flex-shrink: 0; }

/* ===================== 宠物信息 ===================== */
.pet-item {
  border: 1rpx solid #f0ece8;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
}
.pet-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.pet-item-title { font-size: 26rpx; color: #888; font-weight: 600; }

.pet-item-input {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.form-input-full {
  flex: initial;
  width: 100%;
}
/* ===================== 备注区 ===================== */
.note-section { background: #f9f5f1; }

/* ===================== 底部操作栏 ===================== */
.bottom-bar {
  position: fixed;
  z-index: 2;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.08);
}

.btn-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  line-height: 1;
}

.btn-primary {
  background: #E8875A;
  color: #fff;
}
.btn-confirmed {
  background: #5BC47A;
  color: #fff;
}
.btn-secondary {
  background: #f5f0eb;
  color: #666;
  flex: 0.6;
}
.btn-danger {
  background: #fff;
  color: #E54D42;
  border: 1rpx solid #E54D42;
  flex: 0.6;
}

.btn-placeholder {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}
.serving-hint {
  font-size: 26rpx;
  color: #999;
}

.completed-tip {
  text-align: center;
  font-size: 30rpx;
  color: #5BC47A;
  padding: 16rpx 0;
  font-weight: 600;
}
