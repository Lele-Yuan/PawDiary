.visit-page {
  min-height: 100vh;
}

/* 功能未开启时的提示 */
.feature-disabled-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
}

/* 悬浮新建按钮 */
.fab-btn {
  position: fixed;
  right: 40rpx;
  bottom: 200rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #E8875A;
  color: #fff;
  font-size: 52rpx;
  font-weight: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(232, 135, 90, 0.4);
  z-index: 999;
}

/* 加载骨架 */
.loading-wrap {
  padding: 24rpx;
}
.skeleton-card {
  height: 160rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.2s infinite;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}
@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 空状态 */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}
.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}
.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}
.empty-btn {
  background: #E8875A;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
}

/* 列表 */
.visit-list {
  padding: 20rpx 24rpx;
}

.visit-card {
  background: #ffffff80;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.06);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-service-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.card-status-tag {
  font-size: 22rpx;
  color: #fff;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.card-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-icon {
  font-size: 26rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.card-text {
  font-size: 26rpx;
  color: #666;
}

.card-sep {
  font-size: 22rpx;
  color: #ccc;
  margin: 0 10rpx;
}

.card-more {
  font-size: 22rpx;
  color: #E8875A;
  margin-left: 12rpx;
}

.card-address {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 480rpx;
}

.card-next-time {
  color: #5B8DEF;
}
